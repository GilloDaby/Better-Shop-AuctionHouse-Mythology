$C = "../BetterShopCommon.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 720, Height: 460);

    #Title {
      $C.@Title {
        @Text = "";
      }
      Label #PlacementPageTitle {
        Style: (FontSize: 24, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center);
        Anchor: (Height: 32);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 18);

      Label #PlacementSubtitle {
        Style: (FontSize: 12, TextColor: #807868, HorizontalAlignment: Center, VerticalAlignment: Center);
        Text: "Adjust tracker position live for your screen";
        Anchor: (Horizontal: 0, Height: 20, Bottom: 14);
      }

      Group #PlacementCard {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Left: 16, Right: 16, Top: 14, Bottom: 14);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

        Label #PlacementCardTitle {
          Style: (FontSize: 13, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
          Text: "POSITION CONTROLS";
          Anchor: (Height: 22, Bottom: 6);
        }

        Group #PlacementCardDivider {
          Anchor: (Horizontal: 0, Height: 4, Bottom: 12);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
        }

        Group #HeightRow {
          Anchor: (Horizontal: 0, Height: 64, Bottom: 12);
          LayoutMode: Top;
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

          Group #HeightHeaderRow {
            Anchor: (Horizontal: 0, Height: 18, Bottom: 8);
            LayoutMode: Left;

            Label #TrackerPlacementHeightLabel {
              Style: (FontSize: 11, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "HEIGHT";
              FlexWeight: 1;
            }

            Label #TrackerPlacementHeightValue {
              Style: (FontSize: 13, TextColor: #d4a040, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: End);
              Text: "1";
              Anchor: (Width: 90);
            }
          }

          Slider #TrackerPlacementHeightSlider {
            Anchor: (Horizontal: 0, Height: 6);
            Style: $C.@DefaultSliderStyle;
            Min: 0;
            Max: 1080;
            Step: 1;
            Value: 1;
          }
        }

        Group #DistanceRow {
          Anchor: (Horizontal: 0, Height: 64, Bottom: 12);
          LayoutMode: Top;
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

          Group #DistanceHeaderRow {
            Anchor: (Horizontal: 0, Height: 18, Bottom: 8);
            LayoutMode: Left;

            Label #TrackerPlacementDistanceLabel {
              Style: (FontSize: 11, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "DISTANCE";
              FlexWeight: 1;
            }

            Label #TrackerPlacementDistanceValue {
              Style: (FontSize: 13, TextColor: #d4a040, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: End);
              Text: "0";
              Anchor: (Width: 90);
            }
          }

          Slider #TrackerPlacementDistanceSlider {
            Anchor: (Horizontal: 0, Height: 6);
            Style: $C.@DefaultSliderStyle;
            Min: -3000;
            Max: 3000;
            Step: 1;
            Value: 0;
          }
        }

        Label #TrackerPlacementHint {
          Style: (FontSize: 11, TextColor: #807868, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
          Text: "Changes apply instantly. Save keeps your preference.";
          Anchor: (Horizontal: 0, Height: 28);
        }
      }

      Group #PlacementFooter {
        Anchor: (Horizontal: 0, Height: 40, Top: 14);
        LayoutMode: Left;

        $C.@SmallBuyTextButton #TrackerPlacementSaveButton {
          @Anchor = (Width: 200, Height: 36, Right: 8);
          @Text = "SAVE";
        }

        $C.@SmallSecondaryTextButton #TrackerPlacementResetButton {
          @Anchor = (Width: 160, Height: 36, Right: 8);
          @Text = "RESET";
        }

        Group { FlexWeight: 1; }

        $C.@SmallSecondaryTextButton #TrackerPlacementCloseButton {
          @Anchor = (Width: 200, Height: 36);
          @Text = "BACK TO SHOP";
        }
      }
    }
  }
}
