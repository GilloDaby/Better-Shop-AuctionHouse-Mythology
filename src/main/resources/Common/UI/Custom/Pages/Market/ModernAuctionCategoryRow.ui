$C = "../BetterShopCommon.ui";

Group {
  Anchor: (Horizontal: 0, Height: 32, Bottom: 4);
  LayoutMode: Top;

  Button #CategoryButton {
    Anchor: (Horizontal: 0, Height: 32);
    Style: $C.@TertiaryButtonStyle;

    Group {
      Anchor: (Full: 0);
      LayoutMode: Left;
      Padding: (Left: 8, Right: 8);

      Group #CategoryIconWrap {
        Anchor: (Width: 22, Height: 22, Right: 6);
        LayoutMode: CenterMiddle;

        ItemIcon #CategoryIcon {
          Anchor: (Width: 20, Height: 20);
        }
      }

      Label #CategoryName {
        Style: (FontSize: 11, TextColor: #cbd5e1, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
        Text: "Category";
        FlexWeight: 1;
      }

      Label #CategoryCount {
        Style: (FontSize: 10, TextColor: #94a3b8, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: End);
        Text: "0";
        Anchor: (Width: 32);
      }
    }
  }
}
