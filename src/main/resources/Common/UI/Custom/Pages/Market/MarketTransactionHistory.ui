$C = "../BetterShopCommon.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 1240, Height: 880);

    #Title {
      $C.@Title {
        @Text = "";
      }
      Label #PageTitle {
        Style: (FontSize: 22, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center);
        Text: "TRANSACTION LEDGER";
        Anchor: (Height: 30);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Group #ToolbarRow {
        Anchor: (Horizontal: 0, Height: 48, Bottom: 12);
        LayoutMode: Left;

        Button #TabAll {
          Anchor: (Width: 130, Height: 36, Right: 6);
          Padding: (Left: 12, Right: 12);
          Background: (Color: #2a2628);
          LayoutMode: CenterMiddle;

          Label #TabAllText {
            Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "ALL";
          }
        }

        Button #TabShop {
          Anchor: (Width: 130, Height: 36, Right: 6);
          Padding: (Left: 12, Right: 12);
          Background: (Color: #2a2628);
          LayoutMode: CenterMiddle;

          Label #TabShopText {
            Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "SHOP";
          }
        }

        Button #TabAuction {
          Anchor: (Width: 130, Height: 36, Right: 6);
          Padding: (Left: 12, Right: 12);
          Background: (Color: #2a2628);
          LayoutMode: CenterMiddle;

          Label #TabAuctionText {
            Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "AUCTION";
          }
        }

        Button #TabOffer {
          Anchor: (Width: 130, Height: 36, Right: 6);
          Padding: (Left: 12, Right: 12);
          Background: (Color: #2a2628);
          LayoutMode: CenterMiddle;

          Label #TabOfferText {
            Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "OFFER HOUSE";
          }
        }

        Group { FlexWeight: 1; }

        $C.@TextField #LedgerSearchInput {
          @Anchor = (Width: 320, Height: 36);
          PlaceholderText: "Filter item or counterparty...";
        }
      }

      Group #BodyRow {
        FlexWeight: 1;
        LayoutMode: Left;

        Group #PlayersPanel {
          Anchor: (Width: 300, Right: 14);
          LayoutMode: Top;
          Padding: (Left: 12, Right: 12, Top: 12, Bottom: 12);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

          Label #PlayersTitle {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "PLAYERS";
            Anchor: (Height: 18, Bottom: 4);
          }

          Label #PlayersCount {
            Style: (FontSize: 10, TextColor: #d4a040, RenderBold: true, VerticalAlignment: Center);
            Text: "0 active";
            Anchor: (Height: 14, Bottom: 6);
          }

          $C.@TextField #PlayerSearchInput {
            @Anchor = (Horizontal: 0, Height: 32, Bottom: 8);
            PlaceholderText: "Search player...";
          }

          $C.@SmallSecondaryTextButton #PlayerClearSelectionButton {
            @Anchor = (Horizontal: 0, Height: 30, Bottom: 8);
            @Text = "VIEW ALL TRANSACTIONS";
          }

          Group #PlayersDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 8);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Group #PlayersList {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Right: 6);

              Button #PlayerRow0 {
                Visible: false;
                Anchor: (Horizontal: 0, Height: 44, Bottom: 4);
                LayoutMode: Left;
                Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
                Style: (
                  Default: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8)),
                  Hovered: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8)),
                  Pressed: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8))
                );

                Group #PlayerRowAvatar0 {
                  Anchor: (Width: 32, Height: 32, Right: 10);
                  LayoutMode: CenterMiddle;
                  Background: (Color: #2a2628);

                  Label #PlayerRowInitial0 {
                    Style: (FontSize: 14, TextColor: #d4a040, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                    Text: "?";
                  }
                }

                Group {
                  FlexWeight: 1;
                  LayoutMode: CenterMiddle;

                  Group #PlayerRowStack0 {
                    Anchor: (Full: 0);
                    LayoutMode: Top;

                    Label #PlayerRowName0 {
                      Style: (FontSize: 12, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center);
                      Text: "";
                      Anchor: (Height: 16);
                    }

                    Label #PlayerRowMeta0 {
                      Style: (FontSize: 9, TextColor: #807868, VerticalAlignment: Center);
                      Text: "";
                      Anchor: (Height: 12);
                    }
                  }
                }

                Label #PlayerRowSelectedDot0 {
                  Visible: false;
                  Anchor: (Width: 10, Height: 10);
                  Style: (FontSize: 14, TextColor: #d4a040, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                  Text: ">";
                }
              }

              Button #PlayerRow1 {
                Visible: false;
                Anchor: (Horizontal: 0, Height: 44, Bottom: 4);
                LayoutMode: Left;
                Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
                Style: (
                  Default: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8)),
                  Hovered: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8)),
                  Pressed: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8))
