      Group #FooterRow {
        Anchor: (Horizontal: 0, Height: 44, Top: 12);
        LayoutMode: Left;

        $C.@SmallCancelTextButton #BackButton {
          @Anchor = (Width: 130, Height: 36);
          @Text = "CLOSE";
        }

        Group { FlexWeight: 1; }

        $C.@SmallSecondaryTextButton #PrevButton {
          @Anchor = (Width: 130, Height: 36, Right: 10);
          @Text = "< PREV";
        }

        Label #PageIndicator {
          Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "1/1";
          Anchor: (Width: 120, Height: 36);
        }

        $C.@SmallSecondaryTextButton #NextButton {
          @Anchor = (Width: 130, Height: 36);
          @Text = "NEXT >";
        }
      }
