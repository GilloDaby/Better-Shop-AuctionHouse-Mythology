$C = "../BetterShopCommon.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 980, Height: 720);

    #Title {
      $C.@Title {
        @Text = "";
      }
      Label #TitleText {
        Style: (FontSize: 22, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center);
        Text: "BONUS & DISCOUNT QUEUE";
        Anchor: (Height: 30);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Group #StatusRow {
        Anchor: (Horizontal: 0, Height: 110, Bottom: 14);
        LayoutMode: Left;

        Group #SellBoostCard {
          Anchor: (Width: 460, Height: 110, Right: 12);
          LayoutMode: Top;
          Padding: (Left: 16, Right: 16, Top: 12, Bottom: 12);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerFullPatch.png", Border: 14);

          Label #SellBoostBadge {
            Style: (FontSize: 10, TextColor: #4ade80, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "SELL BONUS";
            Anchor: (Horizontal: 0, Height: 14, Bottom: 4);
          }

          Label #SellBoostTimer {
            Style: (FontSize: 24, TextColor: #d4a040, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 14);
            Text: "";
            Anchor: (Horizontal: 0, Height: 32, Bottom: 4);
          }

          Label #SellBoostMain {
            Style: (FontSize: 12, TextColor: #4ade80, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
            Text: "—";
            Anchor: (Horizontal: 0, Height: 18);
          }
        }

        Group #BuyDiscountCard {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Left: 16, Right: 16, Top: 12, Bottom: 12);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerFullPatch.png", Border: 14);

          Label #BuyDiscountBadge {
            Style: (FontSize: 10, TextColor: #d4a040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "SHOP DISCOUNT";
            Anchor: (Horizontal: 0, Height: 14, Bottom: 4);
          }

          Label #BuyDiscountTimer {
            Style: (FontSize: 24, TextColor: #d4a040, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 14);
            Text: "";
            Anchor: (Horizontal: 0, Height: 32, Bottom: 4);
          }

          Label #BuyDiscountMain {
            Style: (FontSize: 12, TextColor: #c08030, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
            Text: "—";
            Anchor: (Horizontal: 0, Height: 18);
          }
        }
      }

      Group #FilterRow {
        Anchor: (Horizontal: 0, Height: 36, Bottom: 12);
        LayoutMode: Left;

        $C.@SmallTextButton #FilterAll {
          @Anchor = (Width: 100, Height: 36, Right: 6);
          @Text = "ALL";
        }

        $C.@SmallSecondaryTextButton #FilterSell {
          @Anchor = (Width: 160, Height: 36, Right: 6);
          @Text = "SELL BONUS";
        }

        $C.@SmallSecondaryTextButton #FilterBuy {
          @Anchor = (Width: 180, Height: 36);
          @Text = "SHOP DISCOUNT";
        }

        Group { FlexWeight: 1; }

        Label #EntryCountLabel {
          Style: (FontSize: 11, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center, HorizontalAlignment: End);
          Text: "0 entries";
          Anchor: (Width: 110, Height: 36);
        }
      }

      Group #QueueListPanel {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Left: 12, Right: 12, Top: 12, Bottom: 12);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

        Group #QueueHeader {
          Anchor: (Horizontal: 0, Height: 22, Bottom: 6);
          LayoutMode: Left;
          Padding: (Left: 12, Right: 12);

          Label {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "PLAYER";
            Anchor: (Width: 130);
          }

          Label {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "TYPE";
            Anchor: (Width: 110);
          }

          Label {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "CATEGORY";
            FlexWeight: 1;
          }

          Label {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center, HorizontalAlignment: End);
            Text: "BONUS";
            Anchor: (Width: 80);
          }

          Label {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center, HorizontalAlignment: End);
            Text: "REMAINING";
            Anchor: (Width: 110);
          }

          Label {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center, HorizontalAlignment: Center);
            Text: "STATUS";
            Anchor: (Width: 90);
          }
        }

        Group #QueueHeaderDivider {
          Anchor: (Horizontal: 0, Height: 4, Bottom: 8);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
        }

        Group #QueueRows {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Right: 6);

          Group #QueueRow0 {
            Visible: false;
            Anchor: (Horizontal: 0, Height: 36, Bottom: 4);
            LayoutMode: Left;
            Padding: (Left: 12, Right: 12, Top: 4, Bottom: 4);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

            Label #QueueRowPlayer0 {
              Style: (FontSize: 11, TextColor: #c08030, RenderBold: true, VerticalAlignment: Center);
              Anchor: (Width: 130, Height: 28);
              Text: "";
            }

            Label #QueueRowType0 {
              Style: (FontSize: 10, TextColor: #d4a040, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
              Anchor: (Width: 110, Height: 28);
              Text: "";
            }

            Label #QueueRowName0 {
              Style: (FontSize: 12, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, Wrap: true);
              FlexWeight: 1;
              Text: "";
            }

            Label #QueueRowPercent0 {
              Style: (FontSize: 13, TextColor: #4ade80, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: End);
              Anchor: (Width: 80, Height: 28);
              Text: "";
            }

            Label #QueueRowTime0 {
              Style: (FontSize: 11, TextColor: #d4a040, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: End);
              Anchor: (Width: 110, Height: 28);
              Text: "";
            }

            Label #QueueRowSlot0 {
              Style: (FontSize: 9, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center, HorizontalAlignment: Center);
              Anchor: (Width: 90, Height: 28);
              Text: "";
            }
          }

