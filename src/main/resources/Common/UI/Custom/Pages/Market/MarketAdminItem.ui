$C = "../BetterShopCommon.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 1280, Height: 900);

    #Title {
      $C.@Title { @Text = ""; }
      Label #PageTitle {
        Style: (FontSize: 22, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center);
        Text: "SHOP ITEM EDITOR";
        Anchor: (Height: 30);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 14);

      Label #AdminIntroText {
        Style: (FontSize: 11, TextColor: #807868, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
        Text: "Configure shop items: identity, pricing, payment mode, flags. The right panel shows a live tile preview.";
        Anchor: (Horizontal: 0, Height: 18, Bottom: 12);
      }

      Group #BodyRow {
        FlexWeight: 1;
        LayoutMode: Left;

        Group #IdentityColumn {
          Anchor: (Width: 380, Right: 12);
          LayoutMode: Top;
          Padding: (Left: 14, Right: 14, Top: 14, Bottom: 14);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

          Label #IdentityTitle {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "ITEM IDENTITY";
            Anchor: (Height: 20, Bottom: 6);
          }

          Group #IdentityDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 12);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Label #ItemIdLabel {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "ITEM ID";
            Anchor: (Height: 14, Bottom: 4);
          }

          $C.@TextField #ItemIdInput {
            @Anchor = (Horizontal: 0, Bottom: 6);
            PlaceholderText: "Soil_Grass";
          }

          $C.@SmallSecondaryTextButton #AddFromHandButton {
            @Anchor = (Horizontal: 0, Height: 30, Bottom: 6);
            @Text = "USE HELD ITEM";
          }

          Label #MetadataHintLabel {
            Style: (FontSize: 9, TextColor: #4a4640, VerticalAlignment: Center, Wrap: true);
            Text: "";
            Anchor: (Horizontal: 0, Height: 22, Bottom: 12);
          }

          Label #CustomNameLabel {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "CUSTOM NAME";
            Anchor: (Height: 14, Bottom: 4);
          }

          $C.@TextField #CustomNameInput {
            @Anchor = (Horizontal: 0, Bottom: 12);
            PlaceholderText: "Optional display name";
          }

          Label #CustomIconPathLabel {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "CUSTOM ICON PATH";
            Anchor: (Height: 14, Bottom: 4);
          }

          Group #CustomIconPathRow {
            Anchor: (Horizontal: 0, Height: 32, Bottom: 4);
            LayoutMode: Left;

            $C.@TextField #CustomIconPathInput {
              @Anchor = (Height: 32, Right: 6);
              FlexWeight: 1;
              PlaceholderText: "Common/Icons/Rank_Hero.png";
            }

            $C.@SmallSecondaryTextButton #BrowseAssetsButton {
              @Anchor = (Width: 110, Height: 32);
              @Text = "BROWSE";
            }
          }

          Label #CustomIconPathHint {
            Style: (FontSize: 9, TextColor: #4a4640, VerticalAlignment: Center, Wrap: true);
            Text: "Pick from all Hytale assets. With a Command on Buy below, Item ID can be left empty.";
            Anchor: (Horizontal: 0, Height: 22, Bottom: 12);
          }

          Group #IdentityFooterDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 12);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Label #CategoryLabel {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "CATEGORY";
            Anchor: (Height: 20, Bottom: 6);
          }

          Group #CategoryDropdownWrap {
            Anchor: (Horizontal: 0, Height: 32, Bottom: 12);
            LayoutMode: Top;

            $C.@DropdownBox #CategoryDropdown {
              @Anchor = (Horizontal: 0, Height: 32);
              NoItemsText: "No categories";
            }
          }

          Group #FlagsDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 12);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Label #FlagsTitle {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "FLAGS & COMMAND";
            Anchor: (Height: 20, Bottom: 8);
          }

          Group #OneTimeOnlyRow {
            Anchor: (Horizontal: 0, Height: 28, Bottom: 4);
            LayoutMode: Left;

            $C.@CheckBox #OneTimeOnlyCheck {
              Anchor: (Width: 22, Height: 22, Right: 8);
              Value: false;
            }

            Label #OneTimeOnlyLabel {
              Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center);
              Text: "One-Time Only";
              FlexWeight: 1;
            }
          }

          Label #OneTimeOnlyHint {
            Style: (FontSize: 9, TextColor: #4a4640, VerticalAlignment: Center, Wrap: true);
            Text: "Removed after first purchase.";
            Anchor: (Horizontal: 0, Height: 12, Bottom: 8);
          }

          Group #BuyDiscountExemptRow {
            Anchor: (Horizontal: 0, Height: 28, Bottom: 4);
            LayoutMode: Left;

            $C.@CheckBox #BuyDiscountExemptCheck {
              Anchor: (Width: 22, Height: 22, Right: 8);
              Value: false;
            }

            Label #BuyDiscountExemptLabel {
              Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center);
              Text: "Exempt from BuyDiscount";
              FlexWeight: 1;
            }
          }

          Label #BuyDiscountExemptHint {
            Style: (FontSize: 9, TextColor: #4a4640, VerticalAlignment: Center, Wrap: true);
            Text: "Skipped by /shop admin buydiscount.";
            Anchor: (Horizontal: 0, Height: 12, Bottom: 12);
          }

          Label #CommandLabel {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "COMMAND ON BUY";
            Anchor: (Height: 14, Bottom: 4);
          }

          $C.@TextField #CommandInput {
            @Anchor = (Horizontal: 0);
            PlaceholderText: "give {player} minecraft:diamond 1";
          }

          Group { FlexWeight: 1; }
        }

        Group #PricingColumn {
          Anchor: (Width: 380, Right: 12);
          LayoutMode: Top;
          Padding: (Left: 14, Right: 14, Top: 14, Bottom: 14);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

          Label #PricingTitle {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "PRICING & QUANTITY";
            Anchor: (Height: 20, Bottom: 6);
          }

          Group #PricingDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 12);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Group #QtyRow {
            Anchor: (Horizontal: 0, Height: 56, Bottom: 12);
            LayoutMode: Left;

            Group #BundleQtyGroup {
              Anchor: (Width: 170, Right: 12);
              LayoutMode: Top;

              Label #BundleQtyLabel {
                Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                Text: "BUNDLE QTY";
                Anchor: (Height: 14, Bottom: 4);
              }

              $C.@TextField #BundleQtyInput {
                @Anchor = (Horizontal: 0);
                PlaceholderText: "1";
              }
            }

            Group #MaxSellQtyGroup {
              FlexWeight: 1;
              LayoutMode: Top;

              Label #MaxSellQtyLabel {
                Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                Text: "MAX SELL QTY";
                Anchor: (Height: 14, Bottom: 4);
              }

              $C.@TextField #MaxSellQtyInput {
                @Anchor = (Horizontal: 0);
                PlaceholderText: "0 = unlimited";
              }
            }
          }

          Group #RefillIntervalRow {
            Anchor: (Horizontal: 0, Height: 50, Bottom: 4);
            LayoutMode: Top;
            Visible: false;

            Label #RefillIntervalLabel {
              Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "REFILL INTERVAL";
              Anchor: (Horizontal: 0, Height: 14, Bottom: 4);
            }

            Group #RefillIntervalDropdownWrap {
              Anchor: (Horizontal: 0, Height: 32);
              LayoutMode: Top;

              $C.@DropdownBox #RefillIntervalDropdown {
                @Anchor = (Horizontal: 0, Height: 32);
                NoItemsText: "—";
              }
            }
          }

          Label #RefillIntervalHint {
            Style: (FontSize: 9, TextColor: #4a4640, VerticalAlignment: Center, Wrap: true);
            Text: "Set Max Sell Qty above 0 to unlock. Stock resets to zero each refill window. One-time = lifetime cap.";
            Anchor: (Horizontal: 0, Height: 22, Bottom: 12);
            Visible: false;
          }

          Group #BuySection {
            Anchor: (Horizontal: 0, Height: 156, Bottom: 12);
            LayoutMode: Top;
            Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

            Group #BuyHeaderRow {
              Anchor: (Horizontal: 0, Height: 26, Bottom: 6);
              LayoutMode: Left;

              Label #BuyModeLabel {
                Style: (FontSize: 11, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                Text: "BUY MODE";
                FlexWeight: 1;
              }

              $C.@SmallSecondaryTextButton #BuyModeButton {
                @Anchor = (Width: 100, Height: 26);
                @Text = "Digital";
              }
            }

            Label #BuyPriceLabel {
              Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "BUY PRICE";
              Anchor: (Height: 14, Bottom: 4);
            }

            $C.@TextField #BuyPriceInput {
              @Anchor = (Horizontal: 0, Bottom: 6);
              PlaceholderText: "100";
            }

            Group #BuyCostRow {
              Anchor: (Horizontal: 0, Height: 32, Bottom: 6);
              LayoutMode: Left;

              $C.@TextField #BuyCostItemIdInput {
                @Anchor = (Height: 32, Right: 6);
                FlexWeight: 1;
                PlaceholderText: "Item_Diamond";
                Visible: false;
              }

              $C.@TextField #BuyCostQtyInput {
                @Anchor = (Width: 70, Height: 32);
                PlaceholderText: "1";
                Visible: false;
              }
            }

            Label #BuyPriceHelpText {
              Style: (FontSize: 9, TextColor: #4a4640, VerticalAlignment: Center, Wrap: true);
              Text: "Digital price per bundle.";
              Anchor: (Horizontal: 0, Height: 14);
            }
          }

          Label #SellPriceLabel {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "SELL PRICE";
            Anchor: (Height: 14, Bottom: 4);
          }

          $C.@TextField #SellPriceInput {
            @Anchor = (Horizontal: 0, Bottom: 12);
            PlaceholderText: "50";
          }

          Group #PrereqDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 12);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Label #PrereqTitle {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "PURCHASE PREREQUISITE";
            Anchor: (Height: 20, Bottom: 6);
          }

          Group #PrereqDropdownWrap {
            Anchor: (Horizontal: 0, Height: 32, Bottom: 12);
            LayoutMode: Top;

            $C.@DropdownBox #PrereqDropdown {
              @Anchor = (Horizontal: 0, Height: 32);
              NoItemsText: "No items in this category";
            }
          }

          Label #LpGroupTitle {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "LUCKPERMS GROUP (OR)";
            Anchor: (Height: 20, Bottom: 6);
          }

          Group #LpGroupDropdownWrap {
            Anchor: (Horizontal: 0, Height: 32);
            LayoutMode: Top;

            $C.@DropdownBox #LpGroupDropdown {
              @Anchor = (Horizontal: 0, Height: 32);
              NoItemsText: "LuckPerms not detected";
            }
          }

          Group { FlexWeight: 1; }
        }

        Group #PreviewColumn {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Left: 14, Right: 14, Top: 14, Bottom: 14);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

          Label #PreviewTitle {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "LIVE PREVIEW";
            Anchor: (Horizontal: 0, Height: 20, Bottom: 6);
          }

          Group #PreviewDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 14);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Group #PreviewTileWrap {
            Anchor: (Horizontal: 0, Height: 220, Bottom: 14);
            LayoutMode: CenterMiddle;

            Group #PreviewTile {
              Anchor: (Width: 180, Height: 220);
              LayoutMode: Top;
              Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

              Group #PreviewIconWrap {
                Anchor: (Horizontal: 0, Height: 110, Bottom: 8);
                Background: (TexturePath: "Textures/MythologyShop/Rarities/SlotCommon.png", Border: 12);

                Group #PreviewIconCenter {
                  Anchor: (Full: 0);
                  LayoutMode: CenterMiddle;

                  AssetImage #PreviewIconAsset {
                    Anchor: (Width: 80, Height: 80);
                    Visible: false;
                  }

                  ItemIcon #PreviewIcon {
                    Anchor: (Width: 80, Height: 80);
                  }
                }

                Label #PreviewQtyBadge {
                  Visible: false;
                  Anchor: (Width: 42, Height: 20, Right: 4, Bottom: 4);
                  Style: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                  Background: (TexturePath: "../../Textures/MythologyShop/Patches/Buttons/Tertiary.png", Border: 6);
                  Text: "x1";
                }

                Label #PreviewCmdBadge {
                  Visible: false;
                  Anchor: (Width: 50, Height: 16, Left: 4, Top: 4);
                  Style: (FontSize: 9, TextColor: #ffffff, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
                  Background: (Color: #d4a040);
                  Text: "REWARD";
                }
              }

              Label #PreviewName {
                Anchor: (Horizontal: 0, Height: 30, Bottom: 6);
                Style: (FontSize: 13, TextColor: #d8d2c4, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 10);
                Text: "Item";
              }

              Group #PreviewPricesRow {
                Anchor: (Horizontal: 0, Height: 44);
                LayoutMode: Left;

                Group #PreviewBuyPill {
                  FlexWeight: 1;
                  Anchor: (Height: 44, Right: 4);
                  LayoutMode: Top;
                  Padding: (Left: 4, Right: 4, Top: 3, Bottom: 3);
                  Background: (TexturePath: "../../Textures/MythologyShop/Patches/Buttons/Tertiary.png", Border: 6);

                  Label {
                    Style: (FontSize: 9, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
                    Text: "BUY";
                    Anchor: (Height: 12);
                  }

                  Label #PreviewBuyPrice {
                    Style: (FontSize: 13, TextColor: #d4a040, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
                    Text: "$0";
                    Anchor: (Height: 22);
                  }
                }

                Group #PreviewSellPill {
                  FlexWeight: 1;
                  Anchor: (Height: 44);
                  LayoutMode: Top;
                  Padding: (Left: 4, Right: 4, Top: 3, Bottom: 3);
                  Background: (TexturePath: "../../Textures/MythologyShop/Patches/Buttons/Tertiary.png", Border: 6);

                  Label {
                    Style: (FontSize: 9, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
                    Text: "SELL";
                    Anchor: (Height: 12);
                  }

                  Label #PreviewSellPrice {
                    Style: (FontSize: 13, TextColor: #94d2bd, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
                    Text: "$0";
                    Anchor: (Height: 22);
                  }
                }
              }
            }
          }

          Group #PreviewSummary {
            Anchor: (Horizontal: 0, Height: 248, Bottom: 8);
            LayoutMode: Top;
            Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

            Label #SummaryTitle {
              Style: (FontSize: 11, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "DETAILS";
              Anchor: (Horizontal: 0, Height: 16, Bottom: 8);
            }

            Group #SummaryRowCategory {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "CATEGORY";
                Anchor: (Width: 90, Height: 16);
              }

              Label #SummaryCategoryValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
                Text: "—";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowRarity {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "RARITY";
                Anchor: (Width: 90, Height: 16);
              }

              Label #SummaryRarityValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center);
                Text: "—";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowStock {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "STOCK CAP";
                Anchor: (Width: 90, Height: 16);
              }

              Label #SummaryStockValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center);
                Text: "Unlimited";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowMode {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "BUY MODE";
                Anchor: (Width: 90, Height: 16);
              }

              Label #SummaryModeValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center);
                Text: "Digital";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowFlags {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "FLAGS";
                Anchor: (Width: 90, Height: 16);
              }

              Label #SummaryFlagsValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center);
                Text: "None";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowCommand {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "REWARD";
                Anchor: (Width: 90, Height: 16);
              }

              Label #SummaryCommandValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
                Text: "Item only";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowIcon {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "ICON SRC";
                Anchor: (Width: 90, Height: 16);
              }

              Label #SummaryIconValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
                Text: "Item ID";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowPrereq {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "PREREQ";
                Anchor: (Width: 90, Height: 16);
              }

              Label #SummaryPrereqValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
                Text: "(none)";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowLpGroup {
              Anchor: (Horizontal: 0, Height: 16);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "LP GROUP";
                Anchor: (Width: 90, Height: 16);
              }

              Label #SummaryLpGroupValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
                Text: "(none)";
                FlexWeight: 1;
              }
            }
          }

          Group { FlexWeight: 1; }

          Group #PreviewRefreshRow {
            Anchor: (Horizontal: 0, Height: 32);
            LayoutMode: CenterMiddle;

            $C.@SmallTertiaryTextButton #RefreshPreviewButton {
              @Anchor = (Width: 200, Height: 32);
              @Text = "REFRESH PREVIEW";
            }
          }
        }
      }

      Group #ActionDivider {
        Anchor: (Horizontal: 0, Height: 4, Top: 12, Bottom: 8);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
      }

      Group #ActionButtons {
        Anchor: (Horizontal: 0, Height: 40);
        LayoutMode: Left;

        $C.@SmallBuyTextButton #SaveButton {
          @Anchor = (Width: 160, Height: 40, Right: 8);
          @Text = "SAVE";
        }

        Group { FlexWeight: 1; }

        $C.@SmallCancelTextButton #DeleteButton {
          @Anchor = (Width: 120, Height: 40, Right: 8);
          @Text = "DELETE";
        }

        $C.@SmallSecondaryTextButton #BackButton {
          @Anchor = (Width: 120, Height: 40);
          @Text = "BACK";
        }
      }
    }
  }
}
