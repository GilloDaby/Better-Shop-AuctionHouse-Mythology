$C = "../BetterShopCommon.ui";

Group {
  Anchor: (Width: 124, Height: 178, Right: 4, Bottom: 6);
  LayoutMode: Top;

  Button #ModernAuctionTile {
    Anchor: (Full: 0);
    LayoutMode: Top;
    Padding: (Left: 6, Right: 6, Top: 6, Bottom: 6);
    Style: (
      Default: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8)),
      Hovered: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8)),
      Pressed: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8))
    );

    Group #ModernAuctionIconWrap {
      Anchor: (Width: 110, Height: 72, Bottom: 4);
      Background: (TexturePath: "Textures/MythologyShop/Rarities/SlotCommon.png", Border: 12);

      Group #ModernAuctionIconCenter {
        Anchor: (Full: 0);
        LayoutMode: CenterMiddle;

        AssetImage #ModernAuctionIconAsset {
          Anchor: (Width: 56, Height: 56);
          Visible: false;
        }

        ItemIcon #ModernAuctionIcon {
          Anchor: (Width: 56, Height: 56);
        }
      }

      Label #ModernAuctionQtyBadge {
        Visible: false;
        Anchor: (Width: 36, Height: 18, Right: 4, Bottom: 4);
        Style: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/Buttons/Tertiary.png", Border: 6);
        Text: "x1";
      }

      Group #ModernAuctionSelectedRing {
        Visible: false;
        Anchor: (Full: 0);
        OutlineColor: #d4a040;
        OutlineSize: 2;
      }

      Label #ModernAuctionBadge {
        Visible: false;
        Anchor: (Width: 50, Height: 16, Left: 4, Bottom: 4);
        Style: (FontSize: 9, TextColor: #ffffff, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
        Background: (Color: #22c55e);
        Text: "BEST";
      }

      Label #ModernAuctionFeaturedBadge {
        Visible: false;
        Anchor: (Width: 70, Height: 16, Right: 4, Top: 4);
        Style: (FontSize: 9, TextColor: #1a1a00, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
        Background: (Color: #d4a040);
        Text: "FEATURED";
      }
    }

    Label #ModernAuctionName {
      Anchor: (Width: 110, Height: 22, Bottom: 2);
      Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9);
      Text: "Item";
    }

    Label #ModernAuctionExpiry {
      Anchor: (Width: 110, Height: 14, Bottom: 4);
      Style: (FontSize: 9, TextColor: #d4a040, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
      Text: "—";
    }

    Group #ModernAuctionPricePill {
      Anchor: (Width: 110, Height: 26);
      LayoutMode: CenterMiddle;
      Padding: (Left: 4, Right: 4);
      Background: (TexturePath: "../../Textures/MythologyShop/Patches/Buttons/Tertiary.png", Border: 6);

      Label #ModernAuctionPrice {
        Style: (FontSize: 12, TextColor: #d4a040, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 7);
        Text: "$0";
      }
    }
  }
}
