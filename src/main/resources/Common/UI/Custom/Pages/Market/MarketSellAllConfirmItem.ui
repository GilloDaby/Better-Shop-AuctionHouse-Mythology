$C = "../BetterShopCommon.ui";

Group {
  Anchor: (Horizontal: 0, Height: 56, Bottom: 6);
  LayoutMode: Left;
  Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);
  Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

  Group #ItemIconWrap {
    Anchor: (Width: 44, Height: 44, Right: 12);
    Background: (TexturePath: "Textures/MythologyShop/Rarities/SlotCommon.png", Border: 8);

    Group {
      Anchor: (Full: 0);
      LayoutMode: CenterMiddle;

      ItemIcon #ItemIcon {
        Anchor: (Width: 32, Height: 32);
      }
    }
  }

  Group #ItemTextCol {
    FlexWeight: 1;
    LayoutMode: Top;
    Padding: (Top: 4, Right: 8);

    Label #ItemName {
      Style: (FontSize: 13, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 10);
      Text: "Item";
      Anchor: (Horizontal: 0, Height: 18);
    }

    Label #ItemUnitPrice {
      Style: (FontSize: 9, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
      Text: "—";
      Anchor: (Horizontal: 0, Height: 12);
    }
  }

  Group #ItemQtyPill {
    Anchor: (Width: 60, Height: 28, Right: 10);
    LayoutMode: CenterMiddle;
    Padding: (Left: 6, Right: 6);
    Background: (Color: #c08030);

    Label #ItemQty {
      Style: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9);
      Text: "x0";
    }
  }

  Group #ItemPricePill {
    Anchor: (Width: 130, Height: 28);
    LayoutMode: CenterMiddle;
    Padding: (Left: 8, Right: 8);
    Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 6);

    Label #ItemPrice {
      Style: (FontSize: 13, TextColor: #d4a040, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 10);
      Text: "$0";
    }
  }
}
