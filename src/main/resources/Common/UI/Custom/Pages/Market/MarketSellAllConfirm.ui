$C = "../BetterShopCommon.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 880, Height: 760);

    #Title {
      $C.@Title { @Text = ""; }
      Label #PageTitle {
        Style: (FontSize: 22, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 3, HorizontalAlignment: Center);
        Text: "CONFIRM SELL ALL";
        Anchor: (Height: 30);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 18);

      Label #SummaryText {
        Style: (FontSize: 11, TextColor: #807868, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
        Text: "Review the items below before confirming.";
        Anchor: (Horizontal: 0, Height: 16, Bottom: 12);
      }

      Group #SummaryCard {
        Anchor: (Horizontal: 0, Height: 130, Bottom: 14);
        LayoutMode: Top;
        Padding: (Left: 16, Right: 16, Top: 14, Bottom: 14);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerFullPatch.png", Border: 14);

        Group #SummaryHeader {
          Anchor: (Horizontal: 0, Height: 26, Bottom: 8);
          LayoutMode: Left;

          Label #SummaryHeaderLabel {
            Style: (FontSize: 9, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "SELLING FROM";
            Anchor: (Width: 110, Height: 18);
          }

          Group #CategoryChip {
            Anchor: (Width: 280, Height: 22);
            LayoutMode: CenterMiddle;
            Padding: (Left: 10, Right: 10);
            Background: (Color: #2563eb);

            Label #CategoryLabel {
              Style: (FontSize: 11, TextColor: #ffffff, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
              Text: "ALL CATEGORIES";
            }
          }
        }

        Group #SummaryStatsRow {
          Anchor: (Horizontal: 0, Height: 64);
          LayoutMode: Left;

          Group #StatItemsTile {
            FlexWeight: 1;
            Anchor: (Height: 64, Right: 8);
            LayoutMode: Top;
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

            Label {
              Style: (FontSize: 9, TextColor: #c08030, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "ITEMS";
              Anchor: (Horizontal: 0, Height: 12, Bottom: 4);
            }
            Label #ItemsCountValue {
              Style: (FontSize: 22, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 14);
              Text: "0";
              Anchor: (Horizontal: 0, Height: 28);
            }
          }

          Group #StatStacksTile {
            FlexWeight: 1;
            Anchor: (Height: 64, Right: 8);
            LayoutMode: Top;
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

            Label {
              Style: (FontSize: 9, TextColor: #8a5020, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "STACKS";
              Anchor: (Horizontal: 0, Height: 12, Bottom: 4);
            }
            Label #StacksCountValue {
              Style: (FontSize: 22, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 14);
              Text: "0";
              Anchor: (Horizontal: 0, Height: 28);
            }
          }

          Group #StatTotalTile {
            FlexWeight: 2;
            Anchor: (Height: 64);
            LayoutMode: Top;
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

            Label {
              Style: (FontSize: 9, TextColor: #d4a040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "TOTAL VALUE";
              Anchor: (Horizontal: 0, Height: 12, Bottom: 4);
            }
            Label #TotalText {
              Style: (FontSize: 22, TextColor: #d4a040, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 12);
              Text: "$0";
              Anchor: (Horizontal: 0, Height: 28);
            }
          }
        }
      }

      Group #PreviewCard {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Left: 14, Right: 14, Top: 12, Bottom: 12);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

        Group #PreviewHeader {
          Anchor: (Horizontal: 0, Height: 20, Bottom: 6);
          LayoutMode: Left;

          Label #PreviewTitle {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "ITEMS TO SELL";
            FlexWeight: 1;
            Anchor: (Height: 18);
          }

          Label #PreviewCountChip {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center, HorizontalAlignment: End);
            Text: "0 ENTRIES";
            Anchor: (Width: 110, Height: 18);
          }
        }

        Group #PreviewDivider {
          Anchor: (Horizontal: 0, Height: 4, Bottom: 8);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
        }

        Group #PreviewScroll {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Right: 6);

          Group #PreviewList {
            LayoutMode: Top;
          }
        }
      }

      Group #SkipRow {
        Anchor: (Horizontal: 0, Height: 28, Top: 12, Bottom: 10);
        LayoutMode: Left;

        $C.@CheckBox #SkipCheck {
          Anchor: (Width: 22, Height: 22, Right: 8);
          Value: false;
        }

        Label #SkipLabel {
          Style: (FontSize: 11, TextColor: #9a958a, VerticalAlignment: Center);
          Text: "Skip confirmation next 24 hours";
          FlexWeight: 1;
        }
      }

      Group #ActionButtons {
        Anchor: (Horizontal: 0, Height: 40);
        LayoutMode: Left;

        $C.@SmallCancelTextButton #BackButton {
          @Anchor = (Width: 160, Height: 36, Right: 8);
          @Text = "BACK";
        }

        $C.@SmallSecondaryTextButton #BlacklistButton {
          @Anchor = (Width: 180, Height: 36, Right: 8);
          @Text = "BLACKLIST ITEM";
        }

        Group { FlexWeight: 1; }

        $C.@SmallBuyTextButton #ConfirmButton {
          @Anchor = (Width: 220, Height: 36);
          @Text = "CONFIRM SELL";
        }
      }
    }
  }
}
