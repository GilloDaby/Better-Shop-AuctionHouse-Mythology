$C = "../BetterShopCommon.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 1280, Height: 900);

    #Title {
      $C.@Title { @Text = ""; }
      Label #PageTitle {
        Style: (FontSize: 22, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center);
        Text: "MANAGE CATEGORIES";
        Anchor: (Height: 30);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 14);

      Label #AdminIntroText {
        Style: (FontSize: 11, TextColor: #807868, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
        Text: "Pick a category on the left to edit, or click NEW CATEGORY. The right panel shows a live sidebar preview.";
        Anchor: (Horizontal: 0, Height: 18, Bottom: 12);
      }

      Group #BodyRow {
        FlexWeight: 1;
        LayoutMode: Left;

        Group #CategoryListColumn {
          Anchor: (Width: 300, Right: 14);
          LayoutMode: Top;
          Padding: (Left: 14, Right: 14, Top: 14, Bottom: 14);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

          Label #CategoryListTitle {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "CATEGORIES";
            Anchor: (Height: 20, Bottom: 6);
          }

          Group #CategoryListDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 12);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          $C.@TextField #CategorySearchInput {
            @Anchor = (Horizontal: 0, Height: 32, Bottom: 8);
            PlaceholderText: "Search...";
          }

          Group #CategoryRows {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Right: 4);

              Button #CategoryRow0 { Anchor: (Horizontal: 0, Height: 38, Bottom: 4); LayoutMode: Left; Padding: (Left: 8, Right: 8); Visible: false; Background: (Color: #1a1a20); Group #CategoryRowIconWrap0 { Anchor: (Width: 28, Height: 28, Right: 8); LayoutMode: CenterMiddle; Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8); AssetImage #CategoryRowIconAsset0 { Anchor: (Width: 22, Height: 22); Visible: false; } ItemIcon #CategoryRowIcon0 { Anchor: (Width: 22, Height: 22); } } Group #CategoryRowText0 { FlexWeight: 1; LayoutMode: Top; Padding: (Top: 4); Label #CategoryRowName0 { Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9); Anchor: (Horizontal: 0, Height: 14); Text: ""; } Label #CategoryRowMeta0 { Style: (FontSize: 9, TextColor: #807868, VerticalAlignment: Center); Anchor: (Horizontal: 0, Height: 12); Text: ""; } } }
              Button #CategoryRow1 { Anchor: (Horizontal: 0, Height: 38, Bottom: 4); LayoutMode: Left; Padding: (Left: 8, Right: 8); Visible: false; Background: (Color: #1a1a20); Group #CategoryRowIconWrap1 { Anchor: (Width: 28, Height: 28, Right: 8); LayoutMode: CenterMiddle; Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8); AssetImage #CategoryRowIconAsset1 { Anchor: (Width: 22, Height: 22); Visible: false; } ItemIcon #CategoryRowIcon1 { Anchor: (Width: 22, Height: 22); } } Group #CategoryRowText1 { FlexWeight: 1; LayoutMode: Top; Padding: (Top: 4); Label #CategoryRowName1 { Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9); Anchor: (Horizontal: 0, Height: 14); Text: ""; } Label #CategoryRowMeta1 { Style: (FontSize: 9, TextColor: #807868, VerticalAlignment: Center); Anchor: (Horizontal: 0, Height: 12); Text: ""; } } }
              Button #CategoryRow2 { Anchor: (Horizontal: 0, Height: 38, Bottom: 4); LayoutMode: Left; Padding: (Left: 8, Right: 8); Visible: false; Background: (Color: #1a1a20); Group #CategoryRowIconWrap2 { Anchor: (Width: 28, Height: 28, Right: 8); LayoutMode: CenterMiddle; Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8); AssetImage #CategoryRowIconAsset2 { Anchor: (Width: 22, Height: 22); Visible: false; } ItemIcon #CategoryRowIcon2 { Anchor: (Width: 22, Height: 22); } } Group #CategoryRowText2 { FlexWeight: 1; LayoutMode: Top; Padding: (Top: 4); Label #CategoryRowName2 { Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9); Anchor: (Horizontal: 0, Height: 14); Text: ""; } Label #CategoryRowMeta2 { Style: (FontSize: 9, TextColor: #807868, VerticalAlignment: Center); Anchor: (Horizontal: 0, Height: 12); Text: ""; } } }
