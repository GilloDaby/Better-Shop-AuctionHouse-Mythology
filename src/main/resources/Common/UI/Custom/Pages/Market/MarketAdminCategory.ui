              Button #CategoryRow24 { Anchor: (Horizontal: 0, Height: 38, Bottom: 4); LayoutMode: Left; Padding: (Left: 8, Right: 8); Visible: false; Background: (Color: #1a1a20); Group #CategoryRowIconWrap24 { Anchor: (Width: 28, Height: 28, Right: 8); LayoutMode: CenterMiddle; Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8); AssetImage #CategoryRowIconAsset24 { Anchor: (Width: 22, Height: 22); Visible: false; } ItemIcon #CategoryRowIcon24 { Anchor: (Width: 22, Height: 22); } } Group #CategoryRowText24 { FlexWeight: 1; LayoutMode: Top; Padding: (Top: 4); Label #CategoryRowName24 { Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9); Anchor: (Horizontal: 0, Height: 14); Text: ""; } Label #CategoryRowMeta24 { Style: (FontSize: 9, TextColor: #807868, VerticalAlignment: Center); Anchor: (Horizontal: 0, Height: 12); Text: ""; } } }
              Button #CategoryRow25 { Anchor: (Horizontal: 0, Height: 38, Bottom: 4); LayoutMode: Left; Padding: (Left: 8, Right: 8); Visible: false; Background: (Color: #1a1a20); Group #CategoryRowIconWrap25 { Anchor: (Width: 28, Height: 28, Right: 8); LayoutMode: CenterMiddle; Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8); AssetImage #CategoryRowIconAsset25 { Anchor: (Width: 22, Height: 22); Visible: false; } ItemIcon #CategoryRowIcon25 { Anchor: (Width: 22, Height: 22); } } Group #CategoryRowText25 { FlexWeight: 1; LayoutMode: Top; Padding: (Top: 4); Label #CategoryRowName25 { Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9); Anchor: (Horizontal: 0, Height: 14); Text: ""; } Label #CategoryRowMeta25 { Style: (FontSize: 9, TextColor: #807868, VerticalAlignment: Center); Anchor: (Horizontal: 0, Height: 12); Text: ""; } } }
              Button #CategoryRow26 { Anchor: (Horizontal: 0, Height: 38, Bottom: 4); LayoutMode: Left; Padding: (Left: 8, Right: 8); Visible: false; Background: (Color: #1a1a20); Group #CategoryRowIconWrap26 { Anchor: (Width: 28, Height: 28, Right: 8); LayoutMode: CenterMiddle; Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8); AssetImage #CategoryRowIconAsset26 { Anchor: (Width: 22, Height: 22); Visible: false; } ItemIcon #CategoryRowIcon26 { Anchor: (Width: 22, Height: 22); } } Group #CategoryRowText26 { FlexWeight: 1; LayoutMode: Top; Padding: (Top: 4); Label #CategoryRowName26 { Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9); Anchor: (Horizontal: 0, Height: 14); Text: ""; } Label #CategoryRowMeta26 { Style: (FontSize: 9, TextColor: #807868, VerticalAlignment: Center); Anchor: (Horizontal: 0, Height: 12); Text: ""; } } }
              Button #CategoryRow27 { Anchor: (Horizontal: 0, Height: 38, Bottom: 4); LayoutMode: Left; Padding: (Left: 8, Right: 8); Visible: false; Background: (Color: #1a1a20); Group #CategoryRowIconWrap27 { Anchor: (Width: 28, Height: 28, Right: 8); LayoutMode: CenterMiddle; Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8); AssetImage #CategoryRowIconAsset27 { Anchor: (Width: 22, Height: 22); Visible: false; } ItemIcon #CategoryRowIcon27 { Anchor: (Width: 22, Height: 22); } } Group #CategoryRowText27 { FlexWeight: 1; LayoutMode: Top; Padding: (Top: 4); Label #CategoryRowName27 { Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9); Anchor: (Horizontal: 0, Height: 14); Text: ""; } Label #CategoryRowMeta27 { Style: (FontSize: 9, TextColor: #807868, VerticalAlignment: Center); Anchor: (Horizontal: 0, Height: 12); Text: ""; } } }
              Button #CategoryRow28 { Anchor: (Horizontal: 0, Height: 38, Bottom: 4); LayoutMode: Left; Padding: (Left: 8, Right: 8); Visible: false; Background: (Color: #1a1a20); Group #CategoryRowIconWrap28 { Anchor: (Width: 28, Height: 28, Right: 8); LayoutMode: CenterMiddle; Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8); AssetImage #CategoryRowIconAsset28 { Anchor: (Width: 22, Height: 22); Visible: false; } ItemIcon #CategoryRowIcon28 { Anchor: (Width: 22, Height: 22); } } Group #CategoryRowText28 { FlexWeight: 1; LayoutMode: Top; Padding: (Top: 4); Label #CategoryRowName28 { Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9); Anchor: (Horizontal: 0, Height: 14); Text: ""; } Label #CategoryRowMeta28 { Style: (FontSize: 9, TextColor: #807868, VerticalAlignment: Center); Anchor: (Horizontal: 0, Height: 12); Text: ""; } } }
              Button #CategoryRow29 { Anchor: (Horizontal: 0, Height: 38, Bottom: 4); LayoutMode: Left; Padding: (Left: 8, Right: 8); Visible: false; Background: (Color: #1a1a20); Group #CategoryRowIconWrap29 { Anchor: (Width: 28, Height: 28, Right: 8); LayoutMode: CenterMiddle; Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8); AssetImage #CategoryRowIconAsset29 { Anchor: (Width: 22, Height: 22); Visible: false; } ItemIcon #CategoryRowIcon29 { Anchor: (Width: 22, Height: 22); } } Group #CategoryRowText29 { FlexWeight: 1; LayoutMode: Top; Padding: (Top: 4); Label #CategoryRowName29 { Style: (FontSize: 11, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9); Anchor: (Horizontal: 0, Height: 14); Text: ""; } Label #CategoryRowMeta29 { Style: (FontSize: 9, TextColor: #807868, VerticalAlignment: Center); Anchor: (Horizontal: 0, Height: 12); Text: ""; } } }
          }

          $C.@SmallBuyTextButton #AddButton {
            @Anchor = (Horizontal: 0, Height: 36, Top: 8);
            @Text = "+ NEW CATEGORY";
          }
        }

        Group #CategoryFormColumn {
          Anchor: (Width: 420, Right: 14);
          LayoutMode: Top;
          Padding: (Left: 14, Right: 14, Top: 14, Bottom: 14);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

          Label #FormTitle {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "CATEGORY DETAILS";
            Anchor: (Height: 20, Bottom: 6);
          }

          Group #FormDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 12);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Label #CategoryIdLabel {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "CATEGORY ID";
            Anchor: (Height: 14, Bottom: 4);
          }

          $C.@TextField #CategoryIdInput {
            @Anchor = (Horizontal: 0, Bottom: 12);
            PlaceholderText: "1";
          }

          Label #CategoryNameLabel {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "NAME";
            Anchor: (Height: 14, Bottom: 4);
          }

          $C.@TextField #CategoryNameInput {
            @Anchor = (Horizontal: 0, Bottom: 12);
            PlaceholderText: "Display name (e.g. Blocks)";
          }

          Label #CategoryPermLabel {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "PERMISSION (optional)";
            Anchor: (Height: 14, Bottom: 4);
          }

          $C.@TextField #CategoryPermInput {
            @Anchor = (Horizontal: 0, Bottom: 4);
            PlaceholderText: "bettershopauction.category.blocks";
          }

          Label #CategoryPermHint {
            Style: (FontSize: 9, TextColor: #4a4640, VerticalAlignment: Center, Wrap: true);
            Text: "Players need this permission to see the category. Leave empty for everyone.";
            Anchor: (Horizontal: 0, Height: 24, Bottom: 12);
          }

          Label #CategoryIconLabel {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "ICON ID OR PATH";
            Anchor: (Height: 14, Bottom: 4);
          }

          Group #CategoryIconRow {
            Anchor: (Horizontal: 0, Height: 32, Bottom: 4);
            LayoutMode: Left;

            $C.@TextField #CategoryIconInput {
              @Anchor = (Height: 32, Right: 6);
              FlexWeight: 1;
              PlaceholderText: "Item_Stone or Icons/Foo.png";
            }

            $C.@SmallSecondaryTextButton #BrowseIconButton {
              @Anchor = (Width: 110, Height: 32);
              @Text = "BROWSE";
            }
          }

          Label #CategoryIconHint {
            Style: (FontSize: 9, TextColor: #4a4640, VerticalAlignment: Center, Wrap: true);
            Text: "Game item id (Item_Stone) or a .png path. Click BROWSE to pick from Hytale assets.";
            Anchor: (Horizontal: 0, Height: 24, Bottom: 12);
          }

          Group #DynamicDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 10);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Label #DynamicTitle {
            Style: (FontSize: 11, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "DYNAMIC PRICING";
            Anchor: (Height: 16, Bottom: 6);
          }

          Group #DynamicRow {
            Anchor: (Horizontal: 0, Height: 32, Bottom: 8);
            LayoutMode: Left;

            Group #DynamicStatusWrap {
              FlexWeight: 1;
              Anchor: (Height: 32, Right: 8);
              LayoutMode: CenterMiddle;
              Padding: (Left: 10, Right: 10);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8);

              Label #DynamicStatusLabel {
                Style: (FontSize: 11, TextColor: #807868, RenderBold: true, VerticalAlignment: Center);
                Text: "OFF";
              }
            }

            $C.@SmallSecondaryTextButton #DynamicToggleButton {
              @Anchor = (Width: 100, Height: 32);
              @Text = "TOGGLE";
            }
          }

          Group #DynamicRangeRow {
            Anchor: (Horizontal: 0, Height: 50, Bottom: 4);
            LayoutMode: Left;

            Group #DynamicMinWrap {
              Anchor: (Height: 50, Right: 8);
              FlexWeight: 1;
              LayoutMode: Top;

              Label #DynamicMinLabel {
                Style: (FontSize: 9, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "MIN MULTIPLIER";
                Anchor: (Horizontal: 0, Height: 12, Bottom: 4);
              }

              $C.@TextField #DynamicMinInput {
                @Anchor = (Horizontal: 0, Height: 32);
                PlaceholderText: "0.5";
              }
            }

            Group #DynamicMaxWrap {
              Anchor: (Height: 50);
              FlexWeight: 1;
              LayoutMode: Top;

              Label #DynamicMaxLabel {
                Style: (FontSize: 9, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "MAX MULTIPLIER";
                Anchor: (Horizontal: 0, Height: 12, Bottom: 4);
              }

              $C.@TextField #DynamicMaxInput {
                @Anchor = (Horizontal: 0, Height: 32);
                PlaceholderText: "2.0";
              }
            }
          }

          Label #DynamicRangeHint {
            Style: (FontSize: 9, TextColor: #4a4640, VerticalAlignment: Center, Wrap: true);
            Text: "Multipliers applied to base price (0.5 = 50% min, 2.0 = 200% max). Leave defaults if unsure.";
            Anchor: (Horizontal: 0, Height: 22, Bottom: 10);
          }

          Group #ReorderDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 10);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Label #ReorderTitle {
            Style: (FontSize: 11, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "REORDER";
            Anchor: (Height: 16, Bottom: 6);
          }

          Group #ReorderRow {
            Anchor: (Horizontal: 0, Height: 32, Bottom: 12);
            LayoutMode: Left;

            $C.@SmallSecondaryTextButton #MoveUpButton {
              @Anchor = (Height: 32, Right: 8);
              @Text = "MOVE UP";
              FlexWeight: 1;
            }

            $C.@SmallSecondaryTextButton #MoveDownButton {
              @Anchor = (Height: 32);
              @Text = "MOVE DOWN";
              FlexWeight: 1;
            }
          }

          Group { FlexWeight: 1; }

          Group #ActionDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 10);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Group #ActionRow {
            Anchor: (Horizontal: 0, Height: 36);
            LayoutMode: Left;

            $C.@SmallBuyTextButton #SaveButton {
              @Anchor = (Width: 140, Height: 36, Right: 8);
              @Text = "SAVE";
            }

            Group { FlexWeight: 1; }

            $C.@SmallCancelTextButton #DeleteButton {
              @Anchor = (Width: 100, Height: 36, Right: 8);
              @Text = "DELETE";
            }

            $C.@SmallSecondaryTextButton #BackButton {
              @Anchor = (Width: 100, Height: 36);
              @Text = "BACK";
            }
          }
        }

        Group #CategoryPreviewColumn {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Left: 14, Right: 14, Top: 14, Bottom: 14);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

          Label #PreviewTitle {
            Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "LIVE PREVIEW";
            Anchor: (Horizontal: 0, Height: 20, Bottom: 6);
          }

          Group #PreviewDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 14);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Label #PreviewSidebarLabel {
            Style: (FontSize: 9, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "AS SHOWN IN /SHOP SIDEBAR";
            Anchor: (Horizontal: 0, Height: 14, Bottom: 6);
          }

          Group #PreviewSidebarRowWrap {
            Anchor: (Horizontal: 0, Height: 64, Bottom: 14);
            LayoutMode: CenterMiddle;
            Padding: (Left: 8, Right: 8);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

            Group #PreviewSidebarRow {
              Anchor: (Horizontal: 0, Height: 44);
              LayoutMode: Left;
              Padding: (Left: 8, Right: 8);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/Buttons/Tertiary.png", Border: 12);

              Group #PreviewIconWrap {
                Anchor: (Width: 30, Height: 30, Right: 8);
                LayoutMode: CenterMiddle;
                Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 6);

                AssetImage #PreviewIconAsset {
                  Anchor: (Width: 22, Height: 22);
                  Visible: false;
                }

                ItemIcon #PreviewIcon {
                  Anchor: (Width: 22, Height: 22);
                }
              }

              Label #PreviewName {
                Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 10);
                Text: "Category";
                FlexWeight: 1;
              }

              Label #PreviewCount {
                Style: (FontSize: 11, TextColor: #807868, VerticalAlignment: Center, HorizontalAlignment: End);
                Text: "0";
                Anchor: (Width: 30, Height: 20);
              }
            }
          }

          Group #PreviewSummary {
            Anchor: (Horizontal: 0, Height: 220, Bottom: 8);
            LayoutMode: Top;
            Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8);

            Label #SummaryTitle {
              Style: (FontSize: 11, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "DETAILS";
              Anchor: (Horizontal: 0, Height: 16, Bottom: 8);
            }

            Group #SummaryRowId {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "ID";
                Anchor: (Width: 100, Height: 16);
              }

              Label #SummaryIdValue {
                Style: (FontSize: 10, TextColor: #c08030, RenderBold: true, VerticalAlignment: Center);
                Text: "—";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowName {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "NAME";
                Anchor: (Width: 100, Height: 16);
              }

              Label #SummaryNameValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
                Text: "—";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowItemsCount {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "ITEMS";
                Anchor: (Width: 100, Height: 16);
              }

              Label #SummaryItemsValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center);
                Text: "0";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowDynamic {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "DYNAMIC";
                Anchor: (Width: 100, Height: 16);
              }

              Label #SummaryDynamicValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center);
                Text: "OFF";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowRange {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "RANGE";
                Anchor: (Width: 100, Height: 16);
              }

              Label #SummaryRangeValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center);
                Text: "0.5x - 2.0x";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowPerm {
              Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "PERMISSION";
                Anchor: (Width: 100, Height: 16);
              }

              Label #SummaryPermValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
                Text: "Public";
                FlexWeight: 1;
              }
            }

            Group #SummaryRowIcon {
              Anchor: (Horizontal: 0, Height: 16);
              LayoutMode: Left;

              Label {
                Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                Text: "ICON";
                Anchor: (Width: 100, Height: 16);
              }

              Label #SummaryIconValue {
                Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
                Text: "—";
                FlexWeight: 1;
              }
            }
          }

          Group { FlexWeight: 1; }

          Label #CategoryListText {
            Visible: false;
            Style: (FontSize: 9, TextColor: #4a4640, Wrap: true);
            Text: "";
            Anchor: (Horizontal: 0);
          }
        }
      }
    }
  }
}
