              Style: (FontSize: 10, TextColor: #4a4640, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "No data yet.";
              Anchor: (Horizontal: 0, Height: 16);
            }
          }
        }

        Group #StatsLeaderboardsRow2 {
          Anchor: (Horizontal: 0);
          FlexWeight: 1;
          LayoutMode: Left;

          Group #StatsLeaderboardAuctionKings {
            FlexWeight: 1;
            Anchor: (Right: 6);
            LayoutMode: Top;
            Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
