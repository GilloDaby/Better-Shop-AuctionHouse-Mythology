      }

      Group #StatsPlayersOverlay {
        Visible: false;
        FlexWeight: 1;
        LayoutMode: Top;

        Group #StatsPlayersHeaderRow {
          Anchor: (Horizontal: 0, Height: 28, Bottom: 6);
          LayoutMode: Left;

          Label #StatsPlayersHeader {
            Style: (FontSize: 14, TextColor: #c08030, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "PLAYER DIRECTORY";
            Anchor: (Width: 240, Height: 22);
          }

          Group { FlexWeight: 1; }

          Group #StatsPlayersStatusPill {
            Anchor: (Width: 140, Height: 24);
            LayoutMode: CenterMiddle;
            Padding: (Left: 8, Right: 8);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8);

            Label #StatsPlayersStatus {
              Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "0 PLAYERS";
            }
          }
        }

        Label #StatsPlayersSubtitle {
          Style: (FontSize: 10, TextColor: #807868, VerticalAlignment: Center);
          Text: "Click anyone to open their trader profile.";
          Anchor: (Horizontal: 0, Height: 14, Bottom: 8);
        }

        Group #StatsPlayersSearchBar {
          Anchor: (Horizontal: 0, Height: 38, Bottom: 10);
          LayoutMode: Left;
          Padding: (Left: 12, Right: 12, Top: 4, Bottom: 4);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerFullPatch.png", Border: 14);

          Label {
            Style: (FontSize: 11, TextColor: #c08030, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "SEARCH";
            Anchor: (Width: 80, Height: 28);
          }

          $C.@TextField #StatsPlayersSearchInput {
            @Anchor = (Height: 28);
            FlexWeight: 1;
            PlaceholderText: "Filter by name";
          }
        }

        Group #StatsPlayersScroll {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          Group #StatsPlayersGrid {
            LayoutMode: LeftCenterWrap;
          }
        }

        Label #StatsPlayersEmpty {
          Visible: false;
          Style: (FontSize: 11, TextColor: #4a4640, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
          Text: "No players known yet.";
          Anchor: (Horizontal: 0, Height: 24, Top: 8);
        }
      }

      Group #StatsFooter {
        Anchor: (Horizontal: 0, Height: 44, Top: 12);
        LayoutMode: Left;

        $C.@SmallSecondaryTextButton #StatsRefreshButton {
          @Anchor = (Width: 160, Height: 36);
          @Text = "REFRESH";
        }

        Group { FlexWeight: 1; }

        $C.@SmallCancelTextButton #StatsBackButton {
          @Anchor = (Width: 160, Height: 36);
          @Text = "BACK TO SHOP";
        }
      }
    }
  }
}
