          }

          Group #AuctionEditDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 12);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Group #AuctionEditBody {
            FlexWeight: 1;
            LayoutMode: Left;

            // ─────────── LEFT: form column ───────────
            Group #AuctionEditFormColumn {
              Anchor: (Width: 500, Right: 14);
              LayoutMode: Top;
              Padding: (Left: 14, Right: 14, Top: 12, Bottom: 12);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

              Group #AuctionEditHeader {
                Anchor: (Horizontal: 0, Height: 80, Bottom: 14);
                LayoutMode: Left;
                Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
                Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8);

                Group #AuctionEditIconWrap {
                  Anchor: (Width: 60, Height: 60, Right: 12);
                  LayoutMode: CenterMiddle;
                  Background: (TexturePath: "Textures/MythologyShop/Rarities/SlotCommon.png", Border: 12);

                  AssetImage #AuctionEditIconAsset {
                    Anchor: (Width: 48, Height: 48);
                    Visible: false;
                  }

                  ItemIcon #AuctionEditIcon {
                    Anchor: (Width: 48, Height: 48);
                  }
                }

                Group {
                  FlexWeight: 1;
                  LayoutMode: CenterMiddle;

                  Group #AuctionEditStack {
                    Anchor: (Full: 0);
                    LayoutMode: Top;

                    Label #AuctionEditName {
                      Style: (FontSize: 16, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, Wrap: true);
                      Text: "Item";
                      Anchor: (Height: 26);
                    }

                    Label #AuctionEditAmount {
                      Style: (FontSize: 11, TextColor: #807868, VerticalAlignment: Center);
                      Text: "x1";
                      Anchor: (Height: 18);
                    }
                  }
                }
              }

              Label #AuctionEditPriceCaption {
                Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                Text: "NEW PRICE";
                Anchor: (Height: 14, Bottom: 4);
              }

              $C.@NumberField #AuctionEditPriceInput {
                @Anchor = (Horizontal: 0, Bottom: 8);
              }

              $C.@SmallBuyTextButton #AuctionEditSavePriceButton {
                @Anchor = (Horizontal: 0, Bottom: 14);
                @Text = "UPDATE PRICE";
              }

              Label #AuctionEditCategoryCaption {
                Style: (FontSize: 10, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                Text: "CATEGORY";
                Anchor: (Height: 14, Bottom: 4);
              }

              Group #AuctionEditCategoryGroup {
                Anchor: (Horizontal: 0, Height: 32, Bottom: 6);
                LayoutMode: Top;

                $C.@DropdownBox #AuctionEditCategoryDropdown {
                  @Anchor = (Horizontal: 0, Height: 32);
                  Value: "uncategorized";
                  DropdownEntry { Value: "uncategorized"; Text: "Uncategorized"; }
                }
              }

              $C.@SmallSecondaryTextButton #AuctionEditCategorySaveButton {
                @Anchor = (Horizontal: 0, Bottom: 14);
                @Text = "UPDATE CATEGORY";
              }


              Group #AuctionEditPromoDivider {
                Anchor: (Horizontal: 0, Height: 4, Bottom: 10);
                Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
              }

              Label #AuctionEditPromoCaption {
                Style: (FontSize: 11, TextColor: #d4a040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
                Text: "LIMITED PROMOTION";
                Anchor: (Height: 16, Bottom: 6);
              }

              Group #AuctionEditPromoRow {
                Anchor: (Horizontal: 0, Height: 32, Bottom: 6);
                LayoutMode: Left;

                $C.@NumberField #AuctionEditPromoPercent {
                  @Anchor = (Width: 110, Right: 6);
                }

                Label #AuctionEditPromoUnit {
                  Style: (FontSize: 11, TextColor: #807868, RenderBold: true, VerticalAlignment: Center);
                  Text: "% OFF";
                  Anchor: (Width: 60, Height: 32, Right: 12);
                }

                $C.@NumberField #AuctionEditPromoDays {
                  @Anchor = (Width: 90, Right: 6);
                }

                Label #AuctionEditPromoDaysUnit {
                  Style: (FontSize: 11, TextColor: #807868, RenderBold: true, VerticalAlignment: Center);
                  Text: "DAYS";
                  Anchor: (Width: 60, Height: 32);
                }
              }

              $C.@SmallBuyTextButton #AuctionEditApplyPromoButton {
                @Anchor = (Horizontal: 0, Bottom: 14);
                @Text = "APPLY PROMOTION";
              }

              Group #AuctionEditFeaturedDivider {
                Anchor: (Horizontal: 0, Height: 4, Bottom: 10);
                Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
              }

              Label #AuctionEditFeaturedCaption {
                Style: (FontSize: 11, TextColor: #d4a040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
                Text: "FEATURED LISTING";
                Anchor: (Height: 16, Bottom: 4);
              }

              Label #AuctionEditFeaturedHint {
                Style: (FontSize: 9, TextColor: #807868, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
                Text: "Featured listings appear at the top of MY LISTINGS with a gold star badge.";
                Anchor: (Horizontal: 0, Height: 22, Bottom: 6);
              }

              Group #AuctionEditFeaturedRow {
                Anchor: (Horizontal: 0, Height: 32, Bottom: 14);
                LayoutMode: Left;

                Group #AuctionEditFeaturedStatusWrap {
                  FlexWeight: 1;
                  Anchor: (Height: 32, Right: 8);
                  LayoutMode: CenterMiddle;
                  Padding: (Left: 10, Right: 10);
                  Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8);

                  Label #AuctionEditFeaturedStatus {
                    Style: (FontSize: 11, TextColor: #807868, RenderBold: true, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9);
                    Text: "OFF";
                  }
                }

                $C.@SmallSecondaryTextButton #AuctionEditFeaturedButton {
                  @Anchor = (Width: 140, Height: 32);
                  @Text = "TOGGLE";
                }
              }

              Group { FlexWeight: 1; }

              Group #AuctionEditActionsDivider {
                Anchor: (Horizontal: 0, Height: 4, Bottom: 10);
                Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
              }

              Group #AuctionEditActions {
                Anchor: (Horizontal: 0, Height: 36);
                LayoutMode: Left;

                $C.@SmallSecondaryTextButton #AuctionEditCloseButton {
                  @Anchor = (Height: 36, Right: 8);
                  @Text = "CLOSE";
                  FlexWeight: 1;
                }

                $C.@SmallCancelTextButton #AuctionEditRemoveButton {
                  @Anchor = (Height: 36);
                  @Text = "REMOVE LISTING";
                  FlexWeight: 1;
                }
              }
            }

            // ─────────── RIGHT: live preview column ───────────
            Group #AuctionEditPreviewColumn {
              FlexWeight: 1;
              LayoutMode: Top;
              Padding: (Left: 14, Right: 14, Top: 12, Bottom: 12);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

              Label #AuctionEditPreviewTitle {
                Style: (FontSize: 12, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
                Text: "LIVE PREVIEW";
                Anchor: (Horizontal: 0, Height: 20, Bottom: 6);
              }

              Group #AuctionEditPreviewDivider {
                Anchor: (Horizontal: 0, Height: 4, Bottom: 14);
                Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
              }

              Group #AuctionEditPreviewTileWrap {
                Anchor: (Horizontal: 0, Height: 290, Bottom: 12);
                LayoutMode: CenterMiddle;

                Group #AuctionEditPreviewTile {
                  Anchor: (Width: 200, Height: 280);
                  LayoutMode: Top;
                  Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
                  Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

                  Group #AuctionEditPreviewIconWrap {
                    Anchor: (Horizontal: 0, Height: 124, Bottom: 6);
                    Background: (TexturePath: "Textures/MythologyShop/Rarities/SlotCommon.png", Border: 12);

                    Group #AuctionEditPreviewIconCenter {
                      Anchor: (Full: 0);
                      LayoutMode: CenterMiddle;

                      AssetImage #AuctionEditPreviewIconAsset {
                        Anchor: (Width: 88, Height: 88);
                        Visible: false;
                      }

                      ItemIcon #AuctionEditPreviewIcon {
                        Anchor: (Width: 88, Height: 88);
                      }
                    }

                    Label #AuctionEditPreviewQtyBadge {
                      Visible: false;
                      Anchor: (Width: 42, Height: 20, Right: 4, Bottom: 4);
                      Style: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                      Background: (TexturePath: "../../Textures/MythologyShop/Patches/Buttons/Tertiary.png", Border: 6);
                      Text: "x1";
                    }

                    Label #AuctionEditPreviewFeaturedBadge {
                      Visible: false;
                      Anchor: (Width: 80, Height: 18, Left: 4, Top: 4);
                      Style: (FontSize: 9, TextColor: #1a1a00, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
                      Background: (Color: #d4a040);
                      Text: "FEATURED";
                    }

                    Label #AuctionEditPreviewPromoBadge {
                      Visible: false;
                      Anchor: (Width: 60, Height: 18, Right: 4, Top: 4);
                      Style: (FontSize: 9, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                      Background: (Color: #b91c1c);
                      Text: "-25%";
                    }
                  }

                  Label #AuctionEditPreviewName {
                    Anchor: (Horizontal: 0, Height: 32, Bottom: 4);
                    Style: (FontSize: 13, TextColor: #d8d2c4, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 10);
                    Text: "Item";
                  }

                  Label #AuctionEditPreviewExpiry {
                    Anchor: (Horizontal: 0, Height: 14, Bottom: 6);
                    Style: (FontSize: 9, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
                    Text: "—";
                  }

                  Group #AuctionEditPreviewPricePill {
                    Anchor: (Horizontal: 0, Height: 36);
                    LayoutMode: CenterMiddle;
                    Padding: (Left: 8, Right: 8);
                    Background: (TexturePath: "../../Textures/MythologyShop/Patches/Buttons/Tertiary.png", Border: 6);

                    Label #AuctionEditPreviewPrice {
                      Style: (FontSize: 14, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 9);
                      Text: "$0";
                    }
                  }
                }
              }

              Group #AuctionEditPreviewSummary {
                Anchor: (Horizontal: 0, Height: 158, Bottom: 8);
                LayoutMode: Top;
                Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
                Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8);

                Label #AuctionEditSummaryTitle {
                  Style: (FontSize: 11, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                  Text: "DETAILS";
                  Anchor: (Horizontal: 0, Height: 16, Bottom: 8);
                }

                Group #AuctionEditSummaryRowOriginal {
                  Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
                  LayoutMode: Left;

                  Label #AuctionEditSummaryLblOriginal {
                    Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                    Text: "ORIGINAL";
                    Anchor: (Width: 100, Height: 16);
                  }

                  Label #AuctionEditSummaryOriginal {
                    Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center);
                    Text: "—";
                    FlexWeight: 1;
                  }
                }

                Group #AuctionEditSummaryRowNew {
                  Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
                  LayoutMode: Left;

                  Label #AuctionEditSummaryLblNew {
                    Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                    Text: "NEW";
                    Anchor: (Width: 100, Height: 16);
                  }

                  Label #AuctionEditSummaryNew {
                    Style: (FontSize: 10, TextColor: #4ade80, RenderBold: true, VerticalAlignment: Center);
                    Text: "—";
                    FlexWeight: 1;
                  }
                }

                Group #AuctionEditSummaryRowPromo {
                  Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
                  LayoutMode: Left;

                  Label #AuctionEditSummaryLblPromotion {
                    Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                    Text: "PROMOTION";
                    Anchor: (Width: 100, Height: 16);
                  }

                  Label #AuctionEditSummaryPromo {
                    Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center);
                    Text: "None";
                    FlexWeight: 1;
                  }
                }

                Group #AuctionEditSummaryRowFeatured {
                  Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
                  LayoutMode: Left;

                  Label #AuctionEditSummaryLblFeatured {
                    Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                    Text: "FEATURED";
                    Anchor: (Width: 100, Height: 16);
                  }

                  Label #AuctionEditSummaryFeatured {
                    Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center);
                    Text: "OFF";
                    FlexWeight: 1;
                  }
                }

                Group #AuctionEditSummaryRowExpiry {
                  Anchor: (Horizontal: 0, Height: 16, Bottom: 4);
                  LayoutMode: Left;

                  Label #AuctionEditSummaryLblExpires {
                    Style: (FontSize: 10, TextColor: #4a4640, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
                    Text: "EXPIRES";
                    Anchor: (Width: 100, Height: 16);
                  }

                  Label #AuctionEditSummaryExpiry {
                    Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, VerticalAlignment: Center);
                    Text: "—";
                    FlexWeight: 1;
                  }
                }
              }

              Group { FlexWeight: 1; }
            }
          }
        }
      }

      Group #AuctionHistoryOverlay {
        Visible: false;
        Anchor: (Width: 1240, Height: 960);
        LayoutMode: Top;
        Padding: (Full: 0);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerFullPatch.png", Border: 14);

        Group #AuctionHistoryHeader {
          Anchor: (Height: 72, Bottom: 10);
          LayoutMode: Left;
          Padding: (Left: 20, Right: 14);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerHeader.png", Border: 14);

          Group {
            FlexWeight: 1;
            LayoutMode: CenterMiddle;

            Group #AuctionHistoryTitleStack {
              Anchor: (Width: 600, Height: 46);
              LayoutMode: Top;

              Label #AuctionHistoryTitle {
                Style: (FontSize: 18, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
                Text: "LISTING HISTORY";
                Anchor: (Height: 24, Bottom: 2);
              }

              Label #AuctionHistorySubtitle {
                Style: (FontSize: 12, TextColor: #807868, HorizontalAlignment: Center, VerticalAlignment: Center);
                Text: "Buyers and sales for this listing";
                Anchor: (Height: 18);
              }
            }
          }

          Group #AuctionHistoryCloseGroup {
            Anchor: (Width: 48);
            LayoutMode: CenterMiddle;

            Button #AuctionHistoryCloseButton {
              Anchor: (Width: 40, Height: 40);
              Style: (
                Default: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerCloseButton.png", Border: 6)),
                Hovered: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerCloseButtonHovered.png", Border: 6)),
                Pressed: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerCloseButtonPressed.png", Border: 6))
              );
            }
          }
        }

        Group #AuctionHistoryBody {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Left: 14, Right: 14, Top: 8, Bottom: 14);

          Group #AuctionHistoryList {
            LayoutMode: Top;
          }

          Label #AuctionHistoryEmpty {
            Visible: false;
            Style: (FontSize: 13, TextColor: #4a4640, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
            Text: "No purchase history yet.";
            Anchor: (Height: 60);
          }
        }
      }
}
