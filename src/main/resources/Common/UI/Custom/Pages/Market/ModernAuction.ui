                }
                Group #AuctionSellSparkSlot1 {
                  Anchor: (Width: 10, Height: 32, Right: 2);
                  Group #AuctionSellSpark1 { Anchor: (Width: 6, Height: 0, Bottom: 0); Background: (Color: #ffd166); }
                }
                Group #AuctionSellSparkSlot2 {
                  Anchor: (Width: 10, Height: 32, Right: 2);
                  Group #AuctionSellSpark2 { Anchor: (Width: 6, Height: 0, Bottom: 0); Background: (Color: #ffd166); }
                }
                Group #AuctionSellSparkSlot3 {
                  Anchor: (Width: 10, Height: 32, Right: 2);
                  Group #AuctionSellSpark3 { Anchor: (Width: 6, Height: 0, Bottom: 0); Background: (Color: #ffd166); }
                }
                Group #AuctionSellSparkSlot4 {
                  Anchor: (Width: 10, Height: 32, Right: 2);
                  Group #AuctionSellSpark4 { Anchor: (Width: 6, Height: 0, Bottom: 0); Background: (Color: #ffd166); }
                }
                Group #AuctionSellSparkSlot5 {
                  Anchor: (Width: 10, Height: 32, Right: 2);
                  Group #AuctionSellSpark5 { Anchor: (Width: 6, Height: 0, Bottom: 0); Background: (Color: #ffd166); }
                }
                Group #AuctionSellSparkSlot6 {
                  Anchor: (Width: 10, Height: 32, Right: 2);
                  Group #AuctionSellSpark6 { Anchor: (Width: 6, Height: 0, Bottom: 0); Background: (Color: #ffd166); }
                }
                Group #AuctionSellSparkSlot7 {
                  Anchor: (Width: 10, Height: 32);
                  Group #AuctionSellSpark7 { Anchor: (Width: 6, Height: 0, Bottom: 0); Background: (Color: #ffd166); }
                }
              }
            }

            Group #AuctionSellBarterSection {
              Visible: false;
              Anchor: (Horizontal: 0);
              LayoutMode: Top;

              Label #AuctionSellBarterCaption {
                Style: (FontSize: 10, TextColor: #8a5020, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                Text: "REQUIRED ITEM (ID)";
