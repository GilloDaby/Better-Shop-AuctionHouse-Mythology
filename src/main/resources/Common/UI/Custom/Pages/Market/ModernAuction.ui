                DropdownEntry { Value: "uncategorized"; Text: "Uncategorized"; }
              }
            }

            Label #AuctionSellPriceCaption {
              Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "PRICE (TOTAL)";
              Anchor: (Height: 14, Bottom: 4);
            }

            $C.@NumberField #AuctionSellPriceInput {
              @Anchor = (Horizontal: 0, Bottom: 10);
            }

            Group #AuctionSellPriceUnitRow {
              Anchor: (Horizontal: 0, Height: 22, Bottom: 10);
              LayoutMode: Left;

              Label #AuctionSellPriceUnitCaption {
                Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                Text: "PRICE PER UNIT:";
