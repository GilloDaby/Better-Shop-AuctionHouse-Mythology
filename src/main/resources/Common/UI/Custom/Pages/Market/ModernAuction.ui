                FlexWeight: 1;
              }

              Label #AuctionSellPayoutValue {
                Style: (FontSize: 12, TextColor: #94d2bd, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: End);
                Text: "$0";
                Anchor: (Width: 120);
              }
            }

            $C.@SmallBuyTextButton #AuctionSellConfirmButton {
              @Anchor = (Horizontal: 0);
              @Text = "LIST FOR SALE";
            }
          }
        }
