$C = "../BetterShopCommon.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  Group #AuctionMainPanel {
    Anchor: (Width: 1240, Height: 960);
    LayoutMode: Top;

  $C.@DecoratedContainer #ModernAuctionRoot {
    Anchor: (Full: 0);

    #Title {
      $C.@Title {
        @Text = "";
      }
      Label #ModernAuctionPageTitle {
        Style: (FontSize: 24, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
        Anchor: (Full: 0);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Horizontal: 14, Top: 2, Bottom: 14);

      Group #AuctionHeaderBar {
        Anchor: (Height: 64, Bottom: 10);
        LayoutMode: Left;
        Padding: (Left: 16, Right: 16, Top: 8, Bottom: 8);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerFullPatch.png", Border: 14);

        Group #AuctionBalanceCard {
          Anchor: (Width: 290, Height: 48, Right: 16);
          LayoutMode: Top;
          Padding: (Left: 14, Right: 14, Top: 4, Bottom: 4);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8);

          Label #AuctionBalanceCaption {
            Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "WALLET BALANCE";
            Anchor: (Height: 14);
          }

          Label #AuctionBalanceValue {
            Style: (FontSize: 19, TextColor: #d4a040, RenderBold: true, VerticalAlignment: Center);
            Text: "$0.00";
            Anchor: (Height: 24);
          }
        }

        Group #AuctionSearchGroup {
          Anchor: (Width: 280, Height: 48);
          LayoutMode: CenterMiddle;

          $C.@CompactTextField #AuctionSearchInput {
            @Anchor = (Width: 280, Height: 40);
            @PlaceholderText = "Search listings...";
            @CollapsedWidth = 280;
            @ExpandedWidth = 280;
          }
        }

        Group { FlexWeight: 1; }

        Group #AuctionSortGroup {
          Anchor: (Width: 160, Height: 48);
          LayoutMode: Top;

          $C.@DropdownBox #AuctionSortDropdown {
            @Anchor = (Horizontal: 0, Height: 32, Top: 8);
            DropdownEntry { Value: "expiry_soon"; Text: "Ending Soon"; }
            DropdownEntry { Value: "expiry_late"; Text: "Ending Late"; }
            DropdownEntry { Value: "price_low_high"; Text: "Price: Low"; }
            DropdownEntry { Value: "price_high_low"; Text: "Price: High"; }
            DropdownEntry { Value: "name_asc"; Text: "Name: A>Z"; }
            DropdownEntry { Value: "name_desc"; Text: "Name: Z>A"; }
          }
        }

        Group #AuctionRarityGroup {
          Anchor: (Width: 160, Height: 48, Left: 8);
          LayoutMode: Top;

          $C.@DropdownBox #AuctionRarityDropdown {
            @Anchor = (Horizontal: 0, Height: 32, Top: 8);
            Value: "";
            DropdownEntry { Value: "";          Text: "All rarities"; }
            DropdownEntry { Value: "common";    Text: "Common"; }
            DropdownEntry { Value: "uncommon";  Text: "Uncommon"; }
            DropdownEntry { Value: "rare";      Text: "Rare"; }
            DropdownEntry { Value: "epic";      Text: "Epic"; }
            DropdownEntry { Value: "legendary"; Text: "Legendary"; }
            DropdownEntry { Value: "sort_up";   Text: "Sort: Rarity Up"; }
            DropdownEntry { Value: "sort_down"; Text: "Sort: Rarity Down"; }
          }
        }

        Group { FlexWeight: 1; }

        Group #AuctionCloseGroup {
          Anchor: (Width: 100, Height: 48);
          LayoutMode: CenterMiddle;

          $C.@SmallCancelTextButton #AuctionCloseButton {
            @Anchor = (Width: 100);
            @Text = "CLOSE";
          }
        }
      }

      Group #AuctionAdminTitleRow {
        Visible: false;
        Anchor: (Horizontal: 0, Height: 44, Bottom: 10);
        LayoutMode: Left;
        Padding: (Left: 16, Right: 16, Top: 6, Bottom: 6);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerFullPatch.png", Border: 14);

        Label #AuctionAdminTitleLabel {
          Style: (FontSize: 10, TextColor: #d4a040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
          Text: "PAGE TITLE";
          Anchor: (Width: 100, Height: 32);
        }

        $C.@TextField #AuctionAdminTitleInput {
          @Anchor = (Height: 32, Right: 8);
          FlexWeight: 1;
          PlaceholderText: "Auction House";
        }

        $C.@SmallSecondaryTextButton #AuctionAdminTitleUpdateButton {
          @Anchor = (Width: 140, Height: 32, Right: 8);
          @Text = "UPDATE TITLE";
        }

        $C.@SmallBuyTextButton #AuctionAdminManageCategoriesButton {
          @Anchor = (Width: 200, Height: 32);
          @Text = "MANAGE CATEGORIES";
        }
      }


      Group #AuctionBodyRow {
        FlexWeight: 1;
        LayoutMode: Left;

        Group #AuctionSidebarPanel {
          Anchor: (Width: 220, Right: 12);
          LayoutMode: Top;
          Padding: (Left: 8, Right: 8, Top: 10, Bottom: 10);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

          Label #AuctionSidebarCategoriesTitle {
            Style: (FontSize: 13, TextColor: #cbd5e1, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "CATEGORIES";
            Anchor: (Height: 22, Bottom: 6);
          }

          Group #AuctionSidebarCatDivider {
            Anchor: (Height: 4, Bottom: 8);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Group #AuctionSidebarCategoriesScroll {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Right: 4);

            Group #AuctionSidebarCategoriesList {
              Anchor: (Horizontal: 0);
              LayoutMode: Top;
            }
          }

          Group #AuctionSidebarTabsDivider {
            Anchor: (Horizontal: 0, Height: 4, Bottom: 8, Top: 8);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Label #AuctionSidebarTitle {
            Style: (FontSize: 13, TextColor: #cbd5e1, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "FILTERS";
            Anchor: (Height: 22, Bottom: 8);
          }

          $C.@SmallTextButton #AuctionTabAll {
            @Anchor = (Horizontal: 0, Bottom: 6);
            @Text = "ALL LISTINGS";
          }

          $C.@SmallSecondaryTextButton #AuctionTabMine {
            @Anchor = (Horizontal: 0, Bottom: 6);
            @Text = "MY LISTINGS";
          }

          $C.@SmallSecondaryTextButton #AuctionTabExpired {
            @Anchor = (Horizontal: 0, Bottom: 6);
            @Text = "EXPIRED";
          }

          $C.@SmallSecondaryTextButton #AuctionTabSold {
            @Anchor = (Horizontal: 0);
            @Text = "RECENTLY SOLD";
          }
        }

        Group #AuctionGridArea {
          FlexWeight: 1;
          LayoutMode: Top;

          Group #AuctionGridHeader {
            Anchor: (Height: 44, Bottom: 8);
            LayoutMode: Left;
            Padding: (Left: 16, Right: 16, Top: 6, Bottom: 6);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

            Label #AuctionGridTitle {
              Style: (FontSize: 18, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center);
              Text: "All Listings";
              FlexWeight: 1;
            }

            Group #AuctionViewModeWrap {
              Anchor: (Width: 130, Height: 32, Right: 12);
              LayoutMode: Top;

              $C.@DropdownBox #AuctionViewModeDropdown {
                @Anchor = (Horizontal: 0, Height: 32);
                Value: "tiles";
                DropdownEntry { Value: "tiles"; Text: "Tiles"; }
                DropdownEntry { Value: "list";  Text: "List";  }
              }
            }


            Label #AuctionResultCount {
              Style: (FontSize: 12, TextColor: #807868, VerticalAlignment: Center);
              Text: "0 listings";
              Anchor: (Width: 130, Height: 18);
            }
          }

          Group #AuctionGridScroll {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@TranslucentScrollbarStyle;

            Group #AuctionListingGrid {
              LayoutMode: LeftCenterWrap;
            }

            Group #AuctionListingGridList {
              Visible: false;
              Anchor: (Horizontal: 0);
              LayoutMode: Top;
            }

            Label #AuctionEmptyState {
              Visible: false;
              Style: (FontSize: 14, TextColor: #4a4640, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
              Text: "No listings to display.";
              Anchor: (Height: 64);
            }
          }

          Group #AuctionPaginationBar {
            Visible: false;
            Anchor: (Height: 36, Top: 8);
            LayoutMode: Left;
            Padding: (Horizontal: 8);

            $C.@SmallSecondaryTextButton #AuctionPagePrev {
              @Anchor = (Width: 140);
              @Text = "< Previous";
            }

            Label #AuctionPageInfo {
              FlexWeight: 1;
              Style: (FontSize: 13, TextColor: #d8d2c4, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "";
            }

            $C.@SmallSecondaryTextButton #AuctionPageNext {
              @Anchor = (Width: 140);
              @Text = "Next >";
            }
          }
        }

        Group #AuctionDetailsPanel {
          Anchor: (Width: 290);
          LayoutMode: Top;
          Padding: (Left: 12, Right: 12, Top: 15, Bottom: 10);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

          Group #AuctionDetailsTitleRow {
            Anchor: (Height: 22, Top: 5, Bottom: 6);
            LayoutMode: Left;

            Label #AuctionDetailsTitle {
              Style: (FontSize: 13, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "LISTING DETAILS";
              FlexWeight: 1;
            }
          }

          Group #AuctionDetailsDivider {
            Anchor: (Height: 4, Bottom: 8);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
          }

          Group #AuctionDetailsPlaceholder {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Top: 4, Bottom: 4);

            Label #AuctionDetailsPlaceholderText {
              Style: (FontSize: 11, TextColor: #475569, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
              Text: "Click a listing to see its full details.";
              Anchor: (Horizontal: 0, Height: 28, Bottom: 10);
            }

            Label #AuctionTopSellersCaption {
              Style: (FontSize: 11, TextColor: #cbd5e1, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "TOP SELLERS";
              Anchor: (Horizontal: 0, Height: 16, Bottom: 6);
            }

            Group #AuctionDetailsTopSellersDivider {
              Anchor: (Horizontal: 0, Height: 4, Bottom: 8);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
            }

            Group #AuctionTopSellersList {
              Anchor: (Horizontal: 0);
              LayoutMode: Top;
              Padding: (Bottom: 10);
            }

            Label #AuctionLatestCaption {
              Style: (FontSize: 11, TextColor: #cbd5e1, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "LATEST PURCHASES";
              Anchor: (Horizontal: 0, Height: 16, Bottom: 6);
            }

            Group #AuctionDetailsLatestDivider {
              Anchor: (Horizontal: 0, Height: 4, Bottom: 8);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
            }

            Group #AuctionLatestList {
              Anchor: (Horizontal: 0);
              LayoutMode: Top;
            }
          }

          Group #AuctionDetailsContent {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Right: 4);
            Visible: false;

            Group #AuctionDetailsHeader {
              Anchor: (Height: 80, Bottom: 8);
              LayoutMode: Left;
              Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

              Group #AuctionDetailsIconWrapper {
                Anchor: (Width: 60, Height: 60, Right: 8);
                LayoutMode: CenterMiddle;
                Background: (TexturePath: "Textures/MythologyShop/Rarities/SlotCommon.png", Border: 12);

                AssetImage #AuctionDetailsItemIconAsset {
                  Anchor: (Width: 48, Height: 48);
                  Visible: false;
                }

                ItemIcon #AuctionDetailsItemIcon {
                  Anchor: (Width: 48, Height: 48);
                }
              }

              Group {
                FlexWeight: 1;
                LayoutMode: CenterMiddle;

                Group #AuctionDetailsTextStack {
                  Anchor: (Full: 0);
                  LayoutMode: Top;

                  Label #AuctionDetailsItemName {
                    Style: (FontSize: 15, TextColor: #d8d2c4, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
                    Text: "Item";
                    Anchor: (Height: 32, Bottom: 4);
                  }

                  Group #AuctionDetailsRarityWrap {
                    Anchor: (Height: 20);
                    LayoutMode: CenterMiddle;

                    Label #AuctionDetailsRarityBadge {
                      Style: (FontSize: 10, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
                      Text: "COMMON";
                      Anchor: (Width: 86, Height: 20);
                      Background: (TexturePath: "../../Textures/MythologyShop/Patches/Buttons/Tertiary.png", Border: 8);
                    }
                  }
                }
              }
            }

            Label #AuctionDetailsSellerCaption {
              Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "SELLER";
              Anchor: (Height: 14, Bottom: 2);
            }

            Label #AuctionDetailsSellerName {
              Style: (FontSize: 13, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center);
              Text: "Unknown";
              Anchor: (Height: 18, Bottom: 8);
            }

            Label #AuctionDetailsExpiryCaption {
              Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "EXPIRES IN";
              Anchor: (Height: 14, Bottom: 2);
            }

            Label #AuctionDetailsExpiry {
              Style: (FontSize: 13, TextColor: #d4a040, RenderBold: true, VerticalAlignment: Center);
              Text: "—";
              Anchor: (Height: 18, Bottom: 8);
            }

            Label #AuctionDetailsAmountCaption {
              Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "QUANTITY";
              Anchor: (Height: 14, Bottom: 2);
            }

            Label #AuctionDetailsAmount {
              Style: (FontSize: 13, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center);
              Text: "x1";
              Anchor: (Height: 18, Bottom: 8);
            }

            Label #AuctionDetailsStatsTitle {
              Style: (FontSize: 11, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "STATS";
              Anchor: (Height: 18, Bottom: 6);
            }

            Group #AuctionDetailsStatsList {
              LayoutMode: Top;
              Padding: (Bottom: 6);
            }

            Label #AuctionDetailsNoStats {
              Visible: false;
              Style: (FontSize: 11, TextColor: #3a342e, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
              Text: "No stats on this item.";
              Anchor: (Height: 28, Bottom: 6);
            }

            Group #AuctionDetailsBuySectionDivider {
              Anchor: (Height: 4, Bottom: 6);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
            }

            Label #AuctionDetailsPriceLabel {
              Style: (FontSize: 12, TextColor: #d4a040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "BUYOUT";
              Anchor: (Height: 18, Bottom: 6);
            }

            Group #AuctionDetailsPriceCard {
              Anchor: (Height: 56, Bottom: 8);
              LayoutMode: Top;
              Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelLightPatch.png", Border: 8);

              Label #AuctionDetailsPriceCaption {
                Style: (FontSize: 9, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
                Text: "TOTAL PRICE";
                Anchor: (Height: 14, Bottom: 2);
              }

              Label #AuctionDetailsPrice {
                Style: (FontSize: 18, TextColor: #d4a040, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 10);
                Text: "$0";
                Anchor: (Height: 26);
              }
            }

            Group #AuctionDetailsQtySection {
              Visible: false;
              Anchor: (Horizontal: 0);
              LayoutMode: Top;

              Label #AuctionDetailsQtyCaption {
                Style: (FontSize: 9, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
                Text: "HOW MANY?";
                Anchor: (Height: 12, Bottom: 4);
              }

              $C.@NumberField #AuctionDetailsQtyInput {
                @Anchor = (Horizontal: 0, Bottom: 6);
                Value: 1;
              }

              Group #AuctionDetailsTotalCard {
                Anchor: (Horizontal: 0, Height: 38, Bottom: 8);
                LayoutMode: Top;
                Padding: (Left: 10, Right: 10, Top: 4, Bottom: 4);
                Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

                Label #AuctionDetailsTotalCaption {
                  Style: (FontSize: 9, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
                  Text: "TOTAL";
                  Anchor: (Height: 12, Bottom: 2);
                }

                Label #AuctionDetailsTotalValue {
                  Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 8);
                  Text: "$0";
                  Anchor: (Height: 18);
                }
              }
            }


            $C.@SmallBuyTextButton #AuctionDetailsBuyButton {
              @Anchor = (Horizontal: 0, Bottom: 8);
              @Text = "BUY NOW";
            }

            $C.@SmallSecondaryTextButton #AuctionDetailsEditButton {
              @Anchor = (Horizontal: 0, Bottom: 6);
              @Text = "EDIT LISTING";
              Visible: false;
            }

            $C.@SmallSecondaryTextButton #AuctionDetailsHistoryButton {
              @Anchor = (Horizontal: 0, Bottom: 6);
              @Text = "VIEW HISTORY";
              Visible: false;
            }

            $C.@SmallSellTextButton #AuctionDetailsReturnButton {
              @Anchor = (Horizontal: 0, Bottom: 6);
              @Text = "RETURN TO INVENTORY";
              Visible: false;
            }

            $C.@SmallCancelTextButton #AuctionDetailsCancelButton {
              @Anchor = (Horizontal: 0);
              @Text = "CANCEL LISTING";
              Visible: false;
            }
          }
        }
      }

      Group #AuctionBottomBar {
        Anchor: (Height: 64, Top: 12);
        LayoutMode: Left;
        Padding: (Left: 14, Right: 14, Top: 8, Bottom: 8);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerFullPatch.png", Border: 14);

        Group #AuctionFooterStatActive {
          Anchor: (Width: 120, Height: 44);
          LayoutMode: Top;
          Padding: (Right: 8);

          Label #AuctionActiveCountCaption {
            Style: (FontSize: 9, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "ACTIVE LISTINGS";
            Anchor: (Height: 12, Bottom: 2);
          }

          Label #AuctionActiveCount {
            Style: (FontSize: 18, TextColor: #f8fafc, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "0";
            Anchor: (Height: 24);
          }
        }

        Group #AuctionFooterStatMine {
          Anchor: (Width: 120, Height: 44);
          LayoutMode: Top;
          Padding: (Right: 12);

          Label #AuctionMyCountCaption {
            Style: (FontSize: 9, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "YOUR LISTINGS";
            Anchor: (Height: 12, Bottom: 2);
          }

          Label #AuctionMyCount {
            Style: (FontSize: 18, TextColor: #94d2bd, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "0";
            Anchor: (Height: 24);
          }
        }

        Label #AuctionBottomHelp {
          Style: (FontSize: 12, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
          Text: "List your own items for sale on the auction house";
          FlexWeight: 1;
        }

        $C.@SmallBuyTextButton #AuctionSellItemButton {
          @Anchor = (Width: 220);
          @Text = "+ NEW LISTING";
        }
      }

      Group #AuctionAdminBottomBar {
        Visible: false;
        Anchor: (Height: 64, Top: 12);
        LayoutMode: Left;
        Padding: (Left: 14, Right: 14, Top: 8, Bottom: 8);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerFullPatch.png", Border: 14);

        Group #AuctionAdminInfoGroup {
          Anchor: (Width: 220, Right: 10);
          LayoutMode: Top;

          Label #AuctionAdminInfoTag {
            Style: (FontSize: 9, TextColor: #d4a040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "ADMIN";
            Anchor: (Height: 12, Bottom: 2);
          }

          Label #AuctionAdminInfoTitle {
            Style: (FontSize: 12, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, Wrap: true);
            Text: "Select a listing to edit";
            Anchor: (Horizontal: 0, Height: 30);
          }
        }

        Group #AuctionAdminPriceGroup {
          Anchor: (Width: 240, Height: 48, Right: 10);
          LayoutMode: Top;
          Visible: false;

          Label {
            Style: (FontSize: 9, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "OVERRIDE PRICE";
            Anchor: (Height: 12, Bottom: 2);
          }

          Group {
            Anchor: (Horizontal: 0, Height: 30);
            LayoutMode: Left;

            $C.@TextField #AuctionAdminPriceInput {
              @Anchor = (Height: 30, Right: 6);
              FlexWeight: 1;
              PlaceholderText: "0";
            }

            $C.@SmallBuyTextButton #AuctionAdminUpdatePriceButton {
              @Anchor = (Width: 70, Height: 30);
              @Text = "SET";
            }
          }
        }

        Group { FlexWeight: 1; }

        Group #AuctionAdminActionsGroup {
          Anchor: (Width: 460, Height: 48);
          LayoutMode: Top;
          Visible: false;

          Label {
            Style: (FontSize: 9, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
            Text: "QUICK ACTIONS";
            Anchor: (Height: 12, Bottom: 2);
          }

          Group {
            Anchor: (Horizontal: 0, Height: 30);
            LayoutMode: Left;

            $C.@SmallSecondaryTextButton #AuctionAdminForceReturnButton {
              @Anchor = (Width: 140, Height: 30, Right: 6);
              @Text = "REFUND";
            }

            $C.@SmallSecondaryTextButton #AuctionAdminForceExpireButton {
              @Anchor = (Width: 140, Height: 30, Right: 6);
              @Text = "FORCE EXPIRE";
            }

            $C.@SmallCancelTextButton #AuctionAdminDeleteButton {
              @Anchor = (Width: 160, Height: 30);
              @Text = "DELETE LISTING";
            }
          }
        }
      }
    }
  }
  }

  Group #AuctionSellOverlay {
        Visible: false;
        Anchor: (Width: 1240, Height: 960);
        LayoutMode: Top;
        Padding: (Full: 0);
        Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerFullPatch.png", Border: 14);

        Group #AuctionSellHeader {
          Anchor: (Height: 72, Bottom: 10);
          LayoutMode: Left;
          Padding: (Left: 20, Right: 14);
          Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerHeader.png", Border: 14);

          Group #AuctionSellHeaderText {
            FlexWeight: 1;
            LayoutMode: CenterMiddle;

            Group #AuctionSellTitleStack {
              Anchor: (Width: 600, Height: 46);
              LayoutMode: Top;

              Label #AuctionSellTitle {
                Style: (FontSize: 18, TextColor: #d8d2c4, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
                Text: "CREATE LISTING";
                Anchor: (Height: 24, Bottom: 2);
              }

              Label #AuctionSellSubtitle {
                Style: (FontSize: 12, TextColor: #807868, HorizontalAlignment: Center, VerticalAlignment: Center);
                Text: "Pick an item from your inventory then set a price";
                Anchor: (Height: 18);
              }
            }
          }

          Group #AuctionSellCloseGroup {
            Anchor: (Width: 48);
            LayoutMode: CenterMiddle;

            Button #AuctionSellCloseButton {
              Anchor: (Width: 40, Height: 40);
              Style: (
                Default: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerCloseButton.png", Border: 6)),
                Hovered: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerCloseButtonHovered.png", Border: 6)),
                Pressed: (Background: PatchStyle(TexturePath: "../../Textures/MythologyShop/Patches/ContainerCloseButtonPressed.png", Border: 6))
              );
            }
          }
        }

        Group #AuctionSellBody {
          FlexWeight: 1;
          LayoutMode: Left;

          Group #AuctionSellInventoryPanel {
            FlexWeight: 1;
            LayoutMode: Top;
            Padding: (Left: 14, Right: 14, Top: 10, Bottom: 10);

            Label #AuctionSellInventoryTitle {
              Style: (FontSize: 13, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "YOUR INVENTORY";
              Anchor: (Height: 22, Bottom: 6);
            }

            Group #AuctionSellInventoryDivider {
              Anchor: (Horizontal: 0, Height: 4, Bottom: 8);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
            }

            Group #AuctionSellInventoryScroll {
              FlexWeight: 1;
              LayoutMode: TopScrolling;
              ScrollbarStyle: $C.@DefaultScrollbarStyle;

              Group #AuctionSellInventoryGrid {
                LayoutMode: LeftCenterWrap;
              }
            }
          }

          Group #AuctionSellFormPanel {
            Anchor: (Width: 360);
            LayoutMode: Top;
            Padding: (Left: 14, Right: 14, Top: 10, Bottom: 10);
            Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPatch.png", Border: 14);

            Label #AuctionSellFormTitle {
              Style: (FontSize: 13, TextColor: #9a958a, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "LISTING DETAILS";
              Anchor: (Height: 22, Bottom: 6);
            }

            Group #AuctionSellFormDivider {
              Anchor: (Horizontal: 0, Height: 4, Bottom: 10);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerSectionSeparator.png", HorizontalBorder: 4);
            }

            Group #AuctionSellSelectedHeader {
              Anchor: (Horizontal: 0, Height: 80, Bottom: 10);
              LayoutMode: Left;
              Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
              Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

              Group #AuctionSellSelectedIconWrap {
                Anchor: (Width: 60, Height: 60, Right: 8);
                LayoutMode: CenterMiddle;
                Background: (TexturePath: "Textures/MythologyShop/Rarities/SlotCommon.png", Border: 12);

                AssetImage #AuctionSellSelectedIconAsset {
                  Anchor: (Width: 48, Height: 48);
                  Visible: false;
                }

                ItemIcon #AuctionSellSelectedIcon {
                  Anchor: (Width: 48, Height: 48);
                  Visible: false;
                }
              }

              Group {
                FlexWeight: 1;
                LayoutMode: CenterMiddle;

                Group #AuctionSellSelectedStack {
                  Anchor: (Full: 0);
                  LayoutMode: Top;

                  Label #AuctionSellSelectedName {
                    Style: (FontSize: 14, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center, Wrap: true);
                    Text: "Pick an item";
                    Anchor: (Height: 30);
                  }

                  Label #AuctionSellSelectedHint {
                    Style: (FontSize: 11, TextColor: #807868, VerticalAlignment: Center);
                    Text: "Click a slot on the left";
                    Anchor: (Height: 18);
                  }
                }
              }
            }

            Label #AuctionSellQtyCaption {
              Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "QUANTITY";
              Anchor: (Height: 14, Bottom: 4);
            }

            $C.@NumberField #AuctionSellQtyInput {
              @Anchor = (Horizontal: 0, Bottom: 10);
            }

            Group #AuctionSellListingTypeRow {
              Anchor: (Horizontal: 0, Height: 30, Bottom: 10);
              LayoutMode: Left;

              $C.@SmallTextButton #AuctionSellTypeFixed {
                @Anchor = (Width: 156, Right: 6);
                @Text = "FIXED PRICE";
              }

              $C.@SmallSecondaryTextButton #AuctionSellTypeAuction {
                @Anchor = (Width: 156);
                @Text = "AUCTION";
              }
            }

            Group #AuctionSellPaymentModeRow {
              Anchor: (Horizontal: 0, Height: 30, Bottom: 10);
