      Group #AuctionBuyConfirmOverlay {
        Visible: false;
        Anchor: (Width: 480, Height: 380);
        LayoutMode: CenterMiddle;

        Group #AuctionBuyConfirmDialog {
          Anchor: (Width: 480, Height: 380);
