              $C.@SmallTextButton #AuctionSellModeDigital {
                @Anchor = (Width: 156, Right: 6);
                @Text = "DIGITAL";
              }

              $C.@SmallSecondaryTextButton #AuctionSellModeBarter {
                @Anchor = (Width: 156);
                @Text = "BARTER";
              }
            }

            Label #AuctionSellCategoryCaption {
              Style: (FontSize: 10, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "CATEGORY";
              Anchor: (Height: 14, Bottom: 4);
            }

            Group #AuctionSellCategoryGroup {
              Anchor: (Horizontal: 0, Height: 32, Bottom: 10);
              LayoutMode: Top;

              $C.@DropdownBox #AuctionSellCategoryDropdown {
                @Anchor = (Horizontal: 0, Height: 32);
