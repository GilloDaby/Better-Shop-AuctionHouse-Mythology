              }

              Label #AuctionSellPriceUnitValue {
                Style: (FontSize: 12, TextColor: #d4a040, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: End);
                Text: "—";
                Anchor: (Width: 140);
              }
            }

            Group #AuctionSellPriceSuggestionRow {
              Visible: false;
              Anchor: (Horizontal: 0, Height: 78, Bottom: 12);
              LayoutMode: Top;
              Padding: (Full: 8);
              Background: (Color: #0b1424);
              OutlineColor: #1e293b;
              OutlineSize: 1;

              Label #AuctionSellSuggestionCaption {
                Style: (FontSize: 9, TextColor: #94a3b8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                Text: "MARKET PRICE";
