            Label #AuctionSellDaysCaption {
              Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
              Text: "DURATION (DAYS)";
              Anchor: (Height: 14, Bottom: 4);
            }

            $C.@NumberField #AuctionSellDaysInput {
              @Anchor = (Horizontal: 0, Bottom: 10);
            }

            $C.@SmallTertiaryTextButton #AuctionSellPromoToggle {
              @Anchor = (Horizontal: 0, Height: 28, Bottom: 8);
              @Text = "+ ADD PROMOTION";
            }

            Group #AuctionSellPromoSection {
              Visible: false;
              Anchor: (Horizontal: 0);
              LayoutMode: Top;

              Label #AuctionSellPromoPercentCaption {
                Style: (FontSize: 10, TextColor: #ef4444, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                Text: "PROMO % OFF";
                Anchor: (Height: 14, Bottom: 4);
              }

              $C.@NumberField #AuctionSellPromoPercent {
                @Anchor = (Horizontal: 0, Bottom: 8);
                Value: 0;
              }

              Label #AuctionSellPromoDaysCaption {
                Style: (FontSize: 10, TextColor: #ef4444, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                Text: "PROMO DURATION (DAYS)";
                Anchor: (Height: 14, Bottom: 4);
              }

              $C.@NumberField #AuctionSellPromoDays {
                @Anchor = (Horizontal: 0, Bottom: 10);
                Value: 1;
              }
            }

            Group #AuctionSellAnnounceCheck {
              Anchor: (Horizontal: 0, Height: 26, Bottom: 6);
              LayoutMode: Left;

              $C.@CheckBox #CheckBox {
                Anchor: (Width: 22, Height: 22, Right: 8);
                Value: false;
              }

              Label #AuctionSellAnnounceLabel {
                Style: (FontSize: 11, TextColor: #cbd5e1, VerticalAlignment: Center);
                Text: "Announce in chat (+10%)";
                FlexWeight: 1;
              }
            }

            Group #AuctionSellFeaturedCheck {
              Anchor: (Horizontal: 0, Height: 26, Bottom: 6);
              LayoutMode: Left;

              $C.@CheckBox #CheckBox {
                Anchor: (Width: 22, Height: 22, Right: 8);
                Value: false;
              }

              Label #AuctionSellFeaturedLabel {
                Style: (FontSize: 11, TextColor: #cbd5e1, VerticalAlignment: Center);
                Text: "Feature this listing (+10% fee)";
                FlexWeight: 1;
              }
            }

            Group #AuctionSellTaxRow {
              Anchor: (Horizontal: 0, Height: 18, Bottom: 10);
              LayoutMode: Left;

              Label #AuctionSellTaxLabel {
                Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
                Text: "TAX:";
                FlexWeight: 1;
              }

              Label #AuctionSellTaxValue {
                Style: (FontSize: 11, TextColor: #ef4444, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: End);
                Text: "$0";
                Anchor: (Width: 120);
              }
            }

            Group #AuctionSellPayoutRow {
              Anchor: (Horizontal: 0, Height: 18, Bottom: 12);
              LayoutMode: Left;

              Label #AuctionSellPayoutLabel {
                Style: (FontSize: 10, TextColor: #807868, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, VerticalAlignment: Center);
