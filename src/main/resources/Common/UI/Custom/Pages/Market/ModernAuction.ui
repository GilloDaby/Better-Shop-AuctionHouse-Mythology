                }

                Label #AuctionSellSuggestionMinMax {
                  Style: (FontSize: 10, TextColor: #6b7280, VerticalAlignment: Center, HorizontalAlignment: End);
                  Text: "";
                  Anchor: (Width: 180);
                }
              }

              Group #AuctionSellSparklineRow {
                Anchor: (Horizontal: 0, Height: 32);
                LayoutMode: Left;
                Padding: (Right: 0);

                Group #AuctionSellSparkSlot0 {
                  Anchor: (Width: 10, Height: 32, Right: 2);
