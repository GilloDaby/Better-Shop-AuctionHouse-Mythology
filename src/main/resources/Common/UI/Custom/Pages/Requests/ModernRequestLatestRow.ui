$C = "../BetterShopCommon.ui";

Group {
  Anchor: (Horizontal: 0, Height: 36, Bottom: 4);
  LayoutMode: Left;
  Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
  Background: (TexturePath: "../../Textures/MythologyShop/Patches/ContainerPanelPatch.png", Border: 8);

  Group #ModernRequestLatestIconWrap {
    Anchor: (Width: 28, Height: 28, Right: 8);
    Background: (TexturePath: "Textures/MythologyShop/Rarities/SlotCommon.png", Border: 8);

    Group #ModernRequestLatestIconCenter {
      Anchor: (Full: 0);
      LayoutMode: CenterMiddle;

      AssetImage #ModernRequestLatestIconAsset {
        Anchor: (Width: 22, Height: 22);
        Visible: false;
      }

      ItemIcon #ModernRequestLatestIcon {
        Anchor: (Width: 22, Height: 22);
      }
    }
  }

  Group {
    FlexWeight: 1;
    LayoutMode: CenterMiddle;

    Group #ModernRequestLatestStack {
      Anchor: (Full: 0);
      LayoutMode: Top;

      Label #ModernRequestLatestName {
        Style: (FontSize: 10, TextColor: #d8d2c4, RenderBold: true, VerticalAlignment: Center);
        Text: "Item x1";
        Anchor: (Height: 14);
      }

      Label #ModernRequestLatestPrice {
        Style: (FontSize: 9, TextColor: #4ade80, RenderBold: true, VerticalAlignment: Center);
        Text: "$0";
        Anchor: (Height: 12);
      }
    }
  }
}
